---
import Layout from '../layouts/Layout.astro';
import StartScreen from '../components/StartScreen.astro';
import ServiceCalculator from '../components/ServiceCalculator.astro';
import ServiceQuizWrapper from '../components/ServiceQuizWrapper.astro';
import DiscountsWrapper from '../components/DiscountsWrapper.astro';
import ServicingWrapper from '../components/ServicingWrapper.astro';
import NumbersWrapper from '../components/NumbersWrapper.astro';
import TopServicesWrapper from '../components/TopServicesWrapper.astro';
import WhyUsWrapper from '../components/WhyUsWrapper.astro';
import AdvantagesWrapper from '../components/AdvantagesWrapper.astro';
import ChillZoneWrapper from '../components/ChillZoneWrapper.astro';

const title = 'YanisGrek - Технический центр по ремонту BMW';
const description = 'Профессиональный ремонт и диагностика BMW. Сертифицированное оборудование, опытная команда, качественный сервис.';
---

<Layout {title} {description}>
  <StartScreen />
  <ServiceCalculator />
  <ServiceQuizWrapper />
  <DiscountsWrapper />
  <ServicingWrapper />
  <ChillZoneWrapper />
  <NumbersWrapper />
  <TopServicesWrapper />
  <WhyUsWrapper />
  <AdvantagesWrapper />
</Layout>
