---
import Layout from '../layouts/Layout.astro';
import ChillZoneWrapper from '../components/ChillZoneWrapper.astro';

const title = 'Контакты - YanisGrek';
const description = 'Свяжитесь с техническим центром YanisGrek.';
---

<Layout {title} {description}>
  <div class="contacts-page">
    {/* Hero Section */}
    <div class="contacts-hero">
      <div class="contacts-hero-content">
        <h1>Контакты</h1>
        <p class="hero-subtitle">Технический центр YanisGrek</p>
      </div>
    </div>

    {/* Contact Info Section */}
    <div class="contact-info-section">
      <div class="contact-info-container">
        <div class="contact-info-left">
          <div class="contact-info-block">
            
            <div class="info-item">
              <h3>Адрес</h3>
              <a href="https://yandex.com/maps/-/CPC7q-mx" target="_blank" rel="noopener noreferrer">Москва, Высоковольтный проезд, 1, стр. 29</a>
            </div>

            <div class="info-item">
              <h3>Телефон</h3>
              <a href="tel:+74957676500">+7 495 76 76 500</a>
            </div>

            <div class="info-item">
              <h3>Режим работы</h3>
              <p>Пн-Пт: 10:00-20:00</p>
              <p>Сб: 11:00-20:00</p>
              <p>Вс: 11:00-18:00</p>
            </div>

            <div class="info-item">
              <h3>Написать нам</h3>
              <div class="messenger-links">
                <a href="https://max.ru/u/f9LHodD0cOIUh8SYqoNqwZ_Kff9bTcJs0_tyGhqUJDVnxYS7JE8D_eIURm0" target="_blank" rel="noopener noreferrer">МАХ</a>
                <a href="https://t.me/+79852707575" target="_blank" rel="noopener noreferrer">Telegram</a>
                <a href="https://wa.me/79852707575" target="_blank" rel="noopener noreferrer">WhatsApp</a>
              </div>
            </div>

            <div class="info-item">
              <h3>Социальные сети</h3>
              <div class="social-links">
                <a href="https://www.youtube.com/c/YanisGrek" target="_blank" rel="noopener noreferrer">YouTube</a>
                <a href="https://t.me/yanis_grek" target="_blank" rel="noopener noreferrer">Telegram</a>
                <a href="https://vk.com/yanis_grek_ru" target="_blank" rel="noopener noreferrer">VK</a>
                <a href="https://www.bmwclub.ru/gallery/photos/yanis-grek.387726/" target="_blank" rel="noopener noreferrer">BMW Club</a>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-info-right">
          <img src="https://s3.regru.cloud/yanis-grek/auto-service/exp2.png" alt="Автосервис YanisGrek" class="contact-image" />
        </div>
      </div>
    </div>

    {/* Contact Form */}
        {/* Contact Form */}
  </div>
  
  <ChillZoneWrapper />

<style>
.contacts-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Hero Section */
.contacts-hero {
  background: linear-gradient(135deg, #262626 0%, #1a1a1a 100%);
  padding: 120px 20px 80px;
  padding-top: 210px;
  color: white;
  text-align: center;
}

.contacts-hero-content {
  max-width: 1200px;
  margin: 0 auto;
}

.contacts-hero h1 {
  font-family: 'Russo One', sans-serif;
  font-size: 48px;
  margin-bottom: 20px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.hero-subtitle {
  font-size: 24px;
  font-weight: 600;
  color: #2b6eff;
}

/* Content */

/* Contact Info Section */
.contact-info-section {
  padding: 80px 20px;
  background: white;
}

.contact-info-container {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}

.contact-info-left h2 {
  font-family: 'Helvetica', sans-serif;
  font-size: 36px;
  font-weight: 600;
  color: #262626;
  margin-bottom: 40px;
}

.info-item {
  margin-bottom: 30px;
}

.info-item h3 {
  font-size: 16px;
  font-weight: 700;
  color: #262626;
  margin-bottom: 10px;
  font-family: 'Helvetica', sans-serif;
}

.info-item p {
  font-size: 16px;
  color: #666;
  line-height: 1.6;
  margin: 5px 0;
}

.info-item a {
  font-size: 16px;
  color: #2b6eff;
  text-decoration: none;
  transition: color 0.3s;
}

.info-item a:hover {
  color: #1e4fbf;
}

.messenger-links,
.social-links {
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
}

.messenger-links a,
.social-links a {
  display: inline-block;
  padding: 8px 16px;
  background: #f5f5f5;
  color: #2b6eff;
  border-radius: 4px;
  font-size: 14px;
  text-decoration: none;
  transition: all 0.3s;
}

.messenger-links a:hover,
.social-links a:hover {
  background: #2b6eff;
  color: white;
}

.contact-info-right {
  display: flex;
  justify-content: center;
}

.contact-image {
  width: 100%;
  height: auto;
  object-fit: cover;
  border-radius: 0;
}

/* Responsive */
@media (max-width: 768px) {
  .contacts-hero h1 {
    font-size: 32px;
  }

  .hero-subtitle {
    font-size: 18px;
  }

  .contact-info-container {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .contact-info-left h2 {
    font-size: 28px;
  }
}

@media (max-width: 480px) {
  .contacts-hero {
    padding: 100px 16px 60px;
  }

  .contacts-hero h1 {
    font-size: 24px;
  }

  .hero-subtitle {
    font-size: 16px;
  }

  .contact-info-section {
    padding: 40px 16px;
  }

  .contact-info-container {
    gap: 30px;
  }

  .contact-info-left h2 {
    font-size: 24px;
  }
}
</style>