---
import Layout from '../../../layouts/Layout.astro';
import NumbersWrapper from '../../../components/NumbersWrapper.astro';
import AdvantagesWrapper from '../../../components/AdvantagesWrapper.astro';
import DiscountsWrapper from '../../../components/DiscountsWrapper.astro';
import ServicingWrapper from '../../../components/ServicingWrapper.astro';
import WhyUsWrapper from '../../../components/WhyUsWrapper.astro';
import { engines, getEngineById } from '../../../assets/engineData';

export async function getStaticPaths() {
  return engines.map(engine => ({
    params: { slug: engine.id }
  }));
}

const { slug } = Astro.params;
const engine = getEngineById(slug);

if (!engine) {
  return Astro.redirect('/404');
}

const typeLabel = engine.type === 'benzine'
  ? 'Бензиновый двигатель'
  : engine.type === 'diesel'
  ? 'Дизельный двигатель'
  : 'Гибридный / Электрический';

const repairOptions = [
  { name: 'Диагностика двигателя', desc: 'Компьютерная диагностика на BMW ICOM, проверка компрессии', price: 'от 1 500 руб.' },
  { name: 'Замена масла и ТО', desc: 'Оригинальное масло BMW, замена фильтра и свечей', price: 'от 9 000 руб.' },
  {
    name: engine.type === 'benzine' ? 'Замена цепи / ремня ГРМ' : engine.type === 'diesel' ? 'Ремонт топливной системы' : 'Диагностика гибридной системы',
    desc: engine.type === 'benzine' ? 'Замена цепи ГРМ с натяжителями и направляющими' : engine.type === 'diesel' ? 'Замена форсунок, очистка ТНВД, DPF' : 'Диагностика батареи, электромоторов, управления',
    price: 'от 20 000 руб.',
  },
  { name: 'Капитальный ремонт', desc: 'Полная разборка, замена поршневой группы и вкладышей', price: engine.priceRange ?? 'от 30 000 руб.' },
];

const faqItems = engine.type === 'benzine' ? [
  { q: `Как понять, что цепь ГРМ ${engine.name} требует замены?`, a: 'Основные признаки: характерный металлический звон или треск в первые 5–10 секунд после запуска двигателя (до прогрева масла), ошибки P0016/P0017 по рассогласованию фаз, рывки при разгоне, нестабильный холостой ход. При появлении звона — немедленно записывайтесь на диагностику, не затягивайте!' },
  { q: 'Как часто нужно менять масло в BMW?', a: 'BMW допускает интервал 15 000–25 000 км по бортовому компьютеру, однако специалисты рекомендуют 7 000–10 000 км для максимального ресурса двигателя. Частая замена масла — лучшая профилактика. Используйте только масло с допуском BMW LL-01 или LL-04.' },
  { q: 'Что делать при повышенном расходе масла?', a: 'Расход до 0.3–0.5 л/10 000 км считается нормой для многих BMW. Если расход выше — требуется диагностика. Возможные причины: изношенные маслосъёмные колпачки, маслосъёмные кольца, сальники клапанов. Диагностика позволяет определить точную причину.' },
  { q: 'Опасно ли продолжать езду при лампе Check Engine?', a: 'Зависит от характера ошибки. При мигающей лампе Check Engine — немедленно прекратите езду и вызовите эвакуатор, это признак серьёзной проблемы. При постоянно горящей лампе — запишитесь на диагностику в ближайшие 1–2 дня.' },
  { q: 'Есть ли гарантия на ремонт двигателя?', a: 'Да, мы предоставляем гарантию 12 месяцев на все выполненные работы и установленные запчасти. На замену масла и ТО — 6 месяцев.' },
  { q: `Используете ли оригинальные запчасти для ${engine.name}?`, a: 'Только оригинальные запчасти BMW или сертифицированные OEM-аналоги производителей первой комплектации: Mahle, Elring, INA, Bosch. Оригинальные масла с допусками BMW LL-01/LL-04.' },
] : engine.type === 'diesel' ? [
  { q: 'Насколько опасна проблема с цепью ГРМ N47/B47?', a: 'Для N47D20 — это критически опасная проблема! Цепь ГРМ может оборваться без предупреждения, что приводит к полному разрушению двигателя. Стоимость замены двигателя после обрыва — 200 000–500 000 руб. Профилактическая замена цепи стоит 20 000–40 000 руб. Выводы очевидны.' },
  { q: 'Как часто нужно менять масло в дизельном BMW?', a: 'Рекомендуем каждые 10 000–15 000 км вне зависимости от показаний бортового компьютера. Дизельные двигатели работают с большим количеством сажи, которая загрязняет масло быстрее. Используйте масло с допуском BMW LL-04 для дизелей.' },
  { q: 'Как часто нужно обслуживать DPF (сажевый фильтр)?', a: 'При преимущественно городской езде сажевый фильтр забивается быстрее. Рекомендуем 1–2 раза в месяц выезжать на трассу и проехать 20–30 км на скорости 80–100 км/ч для принудительной регенерации. Если фильтр полностью забит — принудительная регенерация в сервисе или замена.' },
  { q: 'Что означает потеря мощности у дизельного BMW?', a: 'Потеря мощности у дизеля — признак засорения форсунок, неисправности турбины, забитого DPF или проблем с ТНВД. Требуется диагностика для определения точной причины.' },
  { q: 'Есть ли гарантия на ремонт?', a: 'Да, 12 месяцев на все работы и запасные части.' },
  { q: 'Можно ли удалить DPF/EGR?', a: 'Технически возможно. Мы выполняем программное и физическое удаление DPF, EGR, AdBlue. Однако это влечёт юридические ограничения для эксплуатации на дорогах общего пользования в ряде регионов. Консультируйтесь с нашими специалистами.' },
] : [
  { q: 'Как понять, что высоковольтная батарея деградировала?', a: 'Признаки деградации: значительное сокращение запаса хода на электродвигателе (по сравнению с новым состоянием), медленная зарядка до 100%, быстрый разряд при низких температурах. Диагностика ёмкости батареи позволяет точно оценить состояние.' },
  { q: 'Можно ли ездить при неработающем гибридном режиме?', a: 'Да, автомобиль будет работать в режиме обычного ДВС. Однако расход топлива значительно возрастёт, а неисправность гибридной системы может прогрессировать. Рекомендуем диагностику при первых признаках неисправности.' },
  { q: 'Сколько служит высоковольтная батарея гибрида BMW?', a: 'При правильном обслуживании (зарядка до 80%, не разряжать ниже 20%, избегать экстремальных температур) батарея служит 150 000–200 000 км. BMW даёт заводскую гарантию на батарею 8 лет / 160 000 км.' },
  { q: 'Требуется ли специальное оборудование для гибридов BMW?', a: 'Да. Работа с высоковольтными системами требует: сертифицированного персонала с допуском HV, специального защитного снаряжения, изолирующих инструментов и BMW ICOM Next с модулем HV-диагностики. Наши специалисты имеют все необходимые сертификаты.' },
  { q: 'Есть ли гарантия на ремонт гибридных систем?', a: 'Да, 12 месяцев на все выполненные работы. На замену батарейного модуля — индивидуальная гарантия в зависимости от объёма работ.' },
  { q: 'Можно ли отремонтировать отдельные ячейки батареи?', a: 'Да, в ряде случаев возможна замена только повреждённых ячеек или модулей батарейного блока, что значительно дешевле полной замены батареи. Это определяется по результатам диагностики.' },
];

const title = `Ремонт ${engine.name} BMW - YanisGrek`;
const description = engine.description;
---

<Layout {title} {description}>
  <div class="engine-page" data-type={engine.type}>

    <!-- HERO -->
    <div
      class="engine-hero engine-hero--with-bg"
      style={engine.backgroundImage ? `background-image: url('${engine.backgroundImage}')` : ''}
    >
      <div class="engine-hero-content">
        <div class="engine-hero-left">
          <span class="engine-type-badge">{typeLabel}</span>
          <h1>{engine.name}</h1>
          <p class="engine-models">{engine.models}</p>
          <p class="engine-description">{engine.description}</p>
          <div class="hero-actions">
            {engine.priceRange && (
              <div class="hero-price">
                <span class="hero-price-label">Ремонт</span>
                <span class="hero-price-value">{engine.priceRange}</span>
              </div>
            )}
            <button class="hero-btn" onclick="openQuickRequest()">Записаться на диагностику</button>
          </div>
        </div>
      </div>
      <a class="engine-hero-arrow" href="#engine-specs" aria-label="Прокрутить вниз">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </a>
    </div>

    <!-- SPECS BAR -->
    {engine.specs && (
      <div id="engine-specs" class="specs-bar">
        <div class="specs-bar-inner">
          <div class="spec-item">
            <span class="spec-label">Цилиндры</span>
            <span class="spec-value">{engine.specs.cylinders}</span>
          </div>
          <div class="spec-item">
            <span class="spec-label">Объём</span>
            <span class="spec-value">{engine.specs.displacement}</span>
          </div>
          <div class="spec-item">
            <span class="spec-label">Мощность</span>
            <span class="spec-value">{engine.specs.power}</span>
          </div>
          {engine.specs.torque && (
            <div class="spec-item">
              <span class="spec-label">Момент</span>
              <span class="spec-value">{engine.specs.torque}</span>
            </div>
          )}
          <div class="spec-item">
            <span class="spec-label">Топливо</span>
            <span class="spec-value">{engine.specs.fuelType}</span>
          </div>
          {engine.specs.turbo && (
            <div class="spec-item">
              <span class="spec-label">Наддув</span>
              <span class="spec-value">{engine.specs.turbo}</span>
            </div>
          )}
          {engine.specs.compression && (
            <div class="spec-item">
              <span class="spec-label">Степень сжатия</span>
              <span class="spec-value">{engine.specs.compression}</span>
            </div>
          )}
        </div>
      </div>
    )}

    <div class="engine-content">

      <!-- HIGHLIGHTS -->
      <div class="highlights-section">
        <h2>Ключевые характеристики</h2>
        <div class="highlights-grid">
          {engine.highlights.map(highlight => (
            <div class="highlight-item">
              <div class="highlight-icon">✓</div>
              <p>{highlight}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- SPECIFIC ISSUES (from data) -->
      {engine.issues && engine.issues.length > 0 && (
        <div class="issues-section">
          <div class="issues-left">
            <h2>Известные проблемы {engine.name}</h2>
            <p class="issues-subtitle">Специфические неисправности данной модели двигателя, о которых должен знать каждый владелец BMW</p>
            <div class="issues-list">
              {engine.issues.map(issue => (
                <div class={`issue-item issue-${issue.severity}`}>
                  <div class="issue-header">
                    <span class={`issue-severity severity-${issue.severity}`}>
                      {issue.severity === 'high' ? 'Важно' : issue.severity === 'medium' ? 'Умеренно' : 'Незначительно'}
                    </span>
                    <h4>{issue.title}</h4>
                  </div>
                  <p class="issue-desc">{issue.description}</p>
                  <div class="issue-solution">
                    <span class="solution-label">Решение:</span>
                    <span class="solution-text">{issue.solution}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="issues-right">
            <img src="https://s3.regru.cloud/yanis-grek/engine/oftenproblems.png" alt={`Диагностика двигателя ${engine.name}`} />
            <div class="issues-cta-block">
              <p>Заметили симптомы? Записывайтесь на диагностику</p>
              <button class="issues-cta-btn" onclick="openQuickRequest()">Записаться на диагностику</button>
            </div>
          </div>
        </div>
      )}

      <!-- REPAIR OPTIONS / PRICES -->
      <div class="repair-section">
        <h2>Услуги по ремонту двигателя {engine.name}</h2>
        <p class="section-subtitle">Стоимость работ — точная цена определяется после диагностики</p>
        <div class="repair-grid">
          {repairOptions.map((option, idx) => (
            <div class={`repair-card ${idx === repairOptions.length - 1 ? '' : ''}`}>
              <div class="repair-number">{(idx + 1).toString().padStart(2, '0')}</div>
              <h3>{option.name}</h3>
              <p>{option.desc}</p>
              <div class="repair-price">{option.price}</div>
              <button class="repair-btn" onclick="openQuickRequest()">Записаться</button>
            </div>
          ))}
        </div>
      </div>

      <!-- SERVICES GRID -->
      <div class="services-grid-section">
        <h2>Полный спектр работ с двигателем {engine.name}</h2>
        <div class="services-grid">
          <div class="service-card">
            <img src="https://s3.regru.cloud/yanis-grek/transmission/service1.png" alt="Компьютерная диагностика двигателя" class="service-card-image" />
            <h3>Компьютерная диагностика</h3>
            <p>Полная диагностика на BMW ICOM A2+C, проверка компрессии, измерение давления масла</p>
          </div>
          <div class="service-card">
            <img src="https://s3.regru.cloud/yanis-grek/engine/service2.png" alt="Капитальный ремонт двигателя" class="service-card-image" />
            <h3>Капитальный ремонт</h3>
            <p>Полная разборка, замена поршневых колец, вкладышей, восстановление геометрии</p>
          </div>
          <div class="service-card">
            <img src="https://s3.regru.cloud/yanis-grek/engine/service3.png" alt="Замена деталей двигателя" class="service-card-image" />
            <h3>Замена деталей</h3>
            <p>Цепи ГРМ, прокладок, сальников, форсунок, маслосъёмных колпачков</p>
          </div>
          <div class="service-card">
            <img src="https://s3.regru.cloud/yanis-grek/transmission/service4.png" alt="Промывка двигателя" class="service-card-image" />
            <h3>Промывка и очистка</h3>
            <p>Промывка масляных каналов, чистка клапанов, впускного коллектора, форсунок</p>
          </div>
        </div>
      </div>
    </div>

    <!-- GUARANTEE BLOCK -->
    <div class="guarantee-block">
      <div class="guarantee-inner">
        <div class="guarantee-item">
          <div class="guarantee-icon">12</div>
          <div class="guarantee-text">
            <strong>Гарантия 12 месяцев</strong>
            <span>на все виды работ и запчасти</span>
          </div>
        </div>
        <div class="guarantee-item">
          <div class="guarantee-icon">OEM</div>
          <div class="guarantee-text">
            <strong>Оригинальные запчасти BMW</strong>
            <span>или сертифицированные OEM</span>
          </div>
        </div>
        <div class="guarantee-item">
          <div class="guarantee-icon">BMW</div>
          <div class="guarantee-text">
            <strong>Специалисты по BMW</strong>
            <span>10+ лет опыта с двигателями BMW</span>
          </div>
        </div>
        <div class="guarantee-item">
          <div class="guarantee-icon">0₽</div>
          <div class="guarantee-text">
            <strong>Без скрытых доплат</strong>
            <span>итоговая цена = цена в договоре</span>
          </div>
        </div>
      </div>
    </div>

    <DiscountsWrapper />
    <WhyUsWrapper />
    <ServicingWrapper />
    <NumbersWrapper />

    <!-- FAQ SECTION -->
    <div class="faq-section">
      <div class="faq-inner">
        <h2>Часто задаваемые вопросы</h2>
        <p class="faq-subtitle">Ответы на популярные вопросы о ремонте двигателя {engine.name}</p>
        <div class="faq-list">
          {faqItems.map((item, idx) => (
            <details class="faq-item" open={idx === 0}>
              <summary class="faq-question">{item.q}</summary>
              <p class="faq-answer">{item.a}</p>
            </details>
          ))}
        </div>
        <div class="faq-cta">
          <p>Нужна консультация по двигателю {engine.name}? Позвоните или запишитесь онлайн</p>
          <button class="faq-cta-btn" onclick="openQuickRequest()">Получить консультацию</button>
        </div>
      </div>
    </div>

    <AdvantagesWrapper />
  </div>
</Layout>

<style>
  .engine-page {
    min-height: 100vh;
    margin-top: 90px;
  }

  /* HERO */
  .engine-hero {
    background: #000;
    padding: 80px 20px 60px;
  }

  .engine-hero-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .engine-hero--with-bg {
    background: #000;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    position: relative;
    padding: 120px 20px 80px;
  }

  .engine-hero--with-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .engine-hero--with-bg .engine-hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    min-height: 60vh;
  }

  .engine-hero--with-bg .engine-hero-left {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 24px;
    border-radius: 12px;
    max-width: 560px;
  }

  .engine-hero-arrow {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    animation: bounceArrow 2s ease-in-out infinite;
    opacity: 0.8;
    transition: opacity 0.3s;
  }

  .engine-hero-arrow:hover {
    opacity: 1;
  }

  @keyframes bounceArrow {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(10px); }
  }

  .engine-hero-left {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .engine-type-badge {
    display: inline-block;
    background: #2b6eff;
    color: white;
    font-size: 13px;
    font-weight: 600;
    padding: 6px 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: fit-content;
  }

  .engine-hero h1 {
    font-family: 'Russo One', sans-serif;
    font-size: 48px;
    color: #262626;
    margin: 0;
    text-transform: uppercase;
  }

  .engine-hero--with-bg h1,
  .engine-hero--with-bg .engine-type-badge {
    color: #fff;
  }

  .engine-hero--with-bg .engine-models {
    color: rgba(255, 255, 255, 0.75);
  }

  .engine-hero--with-bg .engine-description {
    color: rgba(255, 255, 255, 0.85);
  }

  .engine-hero--with-bg .hero-btn {
    background: #fff;
    color: #000;
  }

  .engine-hero--with-bg .hero-btn:hover {
    background: #2b6eff;
    color: #fff;
  }

  .engine-models {
    font-size: 16px;
    color: #444;
    font-weight: 500;
    margin: 0;
  }

  .engine-description {
    font-size: 18px;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .hero-price {
    background: #262626;
    color: white;
    padding: 14px 24px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-price-label {
    font-size: 12px;
    font-weight: 400;
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-price-value {
    font-size: 18px;
    font-weight: 700;
  }

  .hero-btn {
    padding: 16px 40px;
    background: black;
    color: white;
    border: none;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s;
  }

  .hero-btn:hover {
    background: #2b6eff;
  }

  .engine-image {
    width: 100%;
    aspect-ratio: 1;
    background: white;
  }

  /* SPECS BAR */
  .specs-bar {
    background: #262626;
    padding: 24px 20px;
  }

  .specs-bar-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .spec-item {
