---
import Layout from '../../../layouts/Layout.astro';
import WhyUsWrapper from '../../../components/WhyUsWrapper.astro';
import NumbersWrapper from '../../../components/NumbersWrapper.astro';
import AdvantagesWrapper from '../../../components/AdvantagesWrapper.astro';
import DiscountsWrapper from '../../../components/DiscountsWrapper.astro';
import ServicingWrapper from '../../../components/ServicingWrapper.astro';
import { transmissions, getTransmissionById } from '../../../assets/transmissionData';

export async function getStaticPaths() {
  return transmissions.map(transmission => ({
    params: { slug: transmission.id }
  }));
}

const { slug } = Astro.params;
const transmission = getTransmissionById(slug);

if (!transmission) {
  return Astro.redirect('/404');
}

const typeLabel = transmission.type === 'mkpp'
  ? 'Механическая коробка передач'
  : transmission.type === 'akpp'
  ? 'Автоматическая коробка передач'
  : transmission.type === 'dct'
  ? 'Роботизированная коробка (DCT)'
  : 'Электрический редуктор';

const repairOptions = transmission.type === 'mkpp' ? [
  { name: 'Диагностика МКПП', desc: 'Компьютерная и механическая диагностика', price: 'от 1 500 руб.' },
  { name: 'Замена масла', desc: 'Оригинальное масло BMW MTF, промывка', price: 'от 4 800 руб.' },
  { name: 'Ремонт синхронизаторов', desc: 'Разборка, замена синхронизаторов и вилок', price: 'от 18 000 руб.' },
  { name: 'Капитальный ремонт', desc: 'Полная разборка и восстановление коробки', price: transmission.priceRange ?? 'от 20 000 руб.' },
] : transmission.type === 'akpp' ? [
  { name: 'Диагностика АКПП', desc: 'Компьютерная диагностика на BMW ICOM', price: 'от 1 500 руб.' },
  { name: 'Замена масла и фильтра', desc: 'Оригинальное масло ATF 9, замена фильтра-картера', price: 'от 21 600 руб.' },
  { name: 'Ремонт гидроблока', desc: 'Диагностика и восстановление мехатроника', price: 'от 25 000 руб.' },
  { name: 'Капитальный ремонт', desc: 'Полная разборка и восстановление АКПП', price: transmission.priceRange ?? 'от 35 000 руб.' },
] : transmission.type === 'dct' ? [
  { name: 'Диагностика DCT', desc: 'Компьютерная диагностика и адаптация сцепления', price: 'от 1 500 руб.' },
  { name: 'Замена масла DCT', desc: 'Оригинальное масло BMW DCT Fluid', price: 'от 18 000 руб.' },
  { name: 'Замена сцепления', desc: 'Замена фрикционных дисков DCT', price: 'от 35 000 руб.' },
  { name: 'Капитальный ремонт', desc: 'Полное восстановление коробки DCT', price: transmission.priceRange ?? 'от 40 000 руб.' },
] : [
  { name: 'Диагностика редуктора EV', desc: 'Диагностика на BMW ICOM Next', price: 'от 2 000 руб.' },
  { name: 'Замена масла редуктора', desc: 'Оригинальное SAF-XO Electric Gear Oil', price: 'от 5 000 руб.' },
  { name: 'Замена подшипников', desc: 'Разборка редуктора, замена подшипников', price: 'от 18 000 руб.' },
  { name: 'Капитальный ремонт', desc: 'Полное восстановление редуктора EV', price: transmission.priceRange ?? 'от 25 000 руб.' },
];

const faqItems = transmission.type === 'mkpp' ? [
  { q: 'Как часто нужно менять масло в МКПП BMW?', a: `Рекомендованный интервал — каждые ${transmission.maintenanceInterval ?? '60 000–80 000 км'}. При активном стиле езды или трековых выездах — каждые 40 000 км. Своевременная замена масла напрямую влияет на ресурс синхронизаторов и подшипников.` },
  { q: 'Как понять, что пора ремонтировать МКПП?', a: 'Основные симптомы: хруст или скрежет при включении передач, тугое включение 2-й или 3-й передачи, самопроизвольное выключение передач, шум в области коробки при движении, течь масла под автомобилем. При любом из этих симптомов — немедленно записывайтесь на диагностику.' },
  { q: 'Сколько времени займёт ремонт?', a: 'Стандартный ремонт синхронизаторов занимает 2–3 рабочих дня. Капитальный ремонт — 3–5 дней. На период ремонта мы можем предложить подменный автомобиль (уточняйте при записи).' },
  { q: 'Что будет, если затянуть с ремонтом?', a: 'Износ синхронизаторов прогрессирует. Металлическая стружка попадает в масло и ускоряет износ шестерён и подшипников. То, что сегодня стоит 15 000 руб. на синхронизаторы, через 20 000 км может превратиться в капитальный ремонт за 60 000+ руб.' },
  { q: 'Даёте ли гарантию на ремонт МКПП?', a: 'Да, мы предоставляем гарантию 12 месяцев на все выполненные работы и установленные запчасти. Гарантия распространяется на стоимость работ и запасных частей.' },
  { q: `Используете ли оригинальные запчасти BMW для ${transmission.name}?`, a: 'Только оригинальные запчасти BMW или сертифицированные аналоги производителей первой комплектации (OEM) — Getrag, ZF. Устанавливаем исключительно масла с допусками BMW.' },
] : transmission.type === 'akpp' ? [
  { q: 'Как часто нужно менять масло в АКПП BMW?', a: `Рекомендованный интервал для ${transmission.name} — каждые ${transmission.maintenanceInterval ?? '40 000–60 000 км'}. Несмотря на заявление BMW о "необслуживаемой АКПП" — это маркетинг. Регулярная замена масла увеличивает ресурс коробки в 2–3 раза.` },
  { q: 'Что означают рывки при переключении?', a: 'Рывки или толчки при переключении — признак износа фрикционов или проблем с гидроблоком. Требуется немедленная диагностика. Продолжение эксплуатации ускоряет износ и превращает ремонт гидроблока в полный капремонт АКПП.' },
  { q: 'Можно ли ездить с горящей лампой АКПП?', a: 'Категорически нет. Аварийный режим или лампа АКПП означают активную проблему. Продолжение езды в аварийном режиме может вызвать полное разрушение коробки. Приезжайте или вызывайте эвакуатор.' },
  { q: 'Сколько времени займёт ремонт АКПП?', a: 'Замена масла и фильтра — 3–4 часа. Ремонт гидроблока — 1–2 дня. Капитальный ремонт — 3–7 рабочих дней в зависимости от сложности.' },
  { q: 'Есть ли гарантия на ремонт?', a: 'Да, гарантия 12 месяцев на все выполненные работы и запасные части. На замену масла и фильтра — 6 месяцев или 15 000 км.' },
  { q: 'Что дешевле — ремонт или замена АКПП?', a: 'В большинстве случаев качественный ремонт значительно дешевле замены. Мы всегда проводим полную диагностику перед ремонтом и честно оцениваем целесообразность.' },
] : transmission.type === 'dct' ? [
  { q: `Почему ${transmission.name} дёргается при трогании?`, a: 'Рывки при трогании — характерная особенность первых поколений DCT. Обычно решается обновлением программного обеспечения блока управления коробкой на BMW ICOM. Если не помогает — диагностика адаптации сцепления.' },
  { q: 'Как часто нужно обслуживать DCT?', a: `Рекомендуем каждые ${transmission.maintenanceInterval ?? '30 000–40 000 км'}. DCT требует более частого обслуживания, чем АКПП, из-за особенностей работы сцепления.` },
  { q: 'Сколько служит сцепление DCT?', a: 'При правильном стиле вождения (плавное трогание, избегание пробок) — 100 000–150 000 км. При городской езде в пробках или агрессивном вождении — 60 000–80 000 км.' },
  { q: 'Опасно ли долго ехать в пробке на DCT?', a: 'Нежелательно. DCT предназначен для динамичной езды, не для длительного ползания в пробках. Перегрев сцепления в пробке ускоряет его износ. Рекомендуем при возможности переходить в нейтраль.' },
  { q: 'Есть ли гарантия на ремонт DCT?', a: 'Да, 12 месяцев на все работы и запасные части.' },
  { q: 'Можно ли обновить ПО DCT самостоятельно?', a: 'Нет. Обновление программного обеспечения блока управления DCT требует профессионального оборудования BMW ICOM и лицензии BMW Software. Самостоятельное обновление невозможно и опасно.' },
] : [
  { q: 'Нужно ли менять масло в редукторе электромобиля?', a: `Да, несмотря на мнение об "обслуживании электромобилей". Рекомендованный интервал для ${transmission.name} — каждые ${transmission.maintenanceInterval ?? '80 000–100 000 км'}. Масло редуктора стареет и загрязняется.` },
  { q: 'Что означает шум при ускорении электромобиля?', a: 'Шум при ускорении электромобиля BMW (вместо обычной тишины) — признак износа подшипников редуктора. Требуется диагностика. Своевременный ремонт подшипников значительно дешевле замены редуктора.' },
  { q: 'Может ли редуктор EV быть отремонтирован?', a: 'Да, в большинстве случаев редуктор электромобиля поддаётся ремонту: замена подшипников, уплотнений, шестерён. Полная замена редуктора требуется только при серьёзных механических повреждениях.' },
  { q: 'Требуется ли специальное оборудование для ремонта EV?', a: 'Да. Работа с высоковольтными системами BMW EV требует сертифицированного персонала и специализированного оборудования. Наши специалисты имеют допуск к работе с HV-системами BMW.' },
  { q: 'Есть ли гарантия на ремонт редуктора?', a: 'Да, гарантия 12 месяцев на все выполненные работы и запасные части.' },
  { q: 'Как часто проверять уровень масла редуктора?', a: 'Рекомендуем проверять при каждом ТО. Уровень масла редуктора критичен для долговечности подшипников и шестерён.' },
];

const title = `Ремонт ${transmission.name} BMW - YanisGrek`;
const description = transmission.description;
---

<Layout {title} {description}>
  <div class="transmission-page" data-type={transmission.type}>

    <!-- HERO -->
    <div class="transmission-hero">
      <div class="transmission-hero-content">
        <div class="transmission-hero-left">
          <span class="transmission-type-badge">{typeLabel}</span>
          <h1>{transmission.name}</h1>
          <p class="transmission-models">{transmission.models}</p>
          <p class="transmission-description">{transmission.description}</p>
          <div class="hero-actions">
            {transmission.priceRange && (
              <div class="hero-price">
                <span class="hero-price-label">Ремонт</span>
                <span class="hero-price-value">{transmission.priceRange}</span>
              </div>
            )}
            <button class="hero-btn" onclick="openQuickRequest()">Записаться на диагностику</button>
          </div>
        </div>
        <div class="transmission-hero-right">
          {(transmission.type === 'mkpp' || transmission.type === 'dct') && transmission.imageUrl && (
            <div
              class="transmission-image"
              style={`background-image: url('${transmission.imageUrl}'); background-size: cover; background-position: center;`}
            ></div>
          )}
        </div>
      </div>
    </div>

    <!-- SPECS BAR -->
    {transmission.specs && (
      <div class="specs-bar">
        <div class="specs-bar-inner">
          <div class="spec-item">
            <span class="spec-label">Ступеней</span>
            <span class="spec-value">{transmission.specs.gears}</span>
          </div>
          <div class="spec-item">
            <span class="spec-label">Макс. момент</span>
            <span class="spec-value">{transmission.specs.maxTorque}</span>
          </div>
          <div class="spec-item">
            <span class="spec-label">Объём масла</span>
            <span class="spec-value">{transmission.specs.oilCapacity}</span>
          </div>
          <div class="spec-item">
            <span class="spec-label">Тип масла</span>
            <span class="spec-value">{transmission.specs.oilType}</span>
          </div>
          <div class="spec-item">
            <span class="spec-label">Производитель</span>
            <span class="spec-value">{transmission.specs.manufacturer}</span>
          </div>
          {transmission.maintenanceInterval && (
            <div class="spec-item">
              <span class="spec-label">Интервал ТО</span>
              <span class="spec-value">{transmission.maintenanceInterval}</span>
            </div>
          )}
        </div>
      </div>
    )}

    <div class="transmission-content">

      <!-- HIGHLIGHTS -->
      <div class="highlights-section">
        <h2>Ключевые характеристики</h2>
        <div class="highlights-grid">
          {transmission.highlights.map(highlight => (
            <div class="highlight-item">
              <div class="highlight-icon">✓</div>
              <p>{highlight}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- SPECIFIC PROBLEMS (from data) -->
      {transmission.issues && transmission.issues.length > 0 && (
        <div class="issues-section">
          <div class="issues-left">
            <h2>Известные проблемы {transmission.name}</h2>
            <p class="issues-subtitle">Специфические неисправности данной модели коробки передач, о которых должен знать каждый владелец</p>
            <div class="issues-list">
              {transmission.issues.map(issue => (
                <div class={`issue-item issue-${issue.severity}`}>
                  <div class="issue-header">
                    <span class={`issue-severity severity-${issue.severity}`}>
                      {issue.severity === 'high' ? 'Важно' : issue.severity === 'medium' ? 'Умеренно' : 'Незначительно'}
                    </span>
                    <h4>{issue.title}</h4>
                  </div>
                  <p class="issue-desc">{issue.description}</p>
                  <div class="issue-solution">
                    <span class="solution-label">Решение:</span>
                    <span class="solution-text">{issue.solution}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="issues-right">
            <img src="https://s3.regru.cloud/yanis-grek/transmission/oftenproblems.png" alt={`Проблемы ${transmission.name}`} />
            <div class="issues-cta-block">
              <p>Заметили один из этих симптомов?</p>
              <button class="issues-cta-btn" onclick="openQuickRequest()">Записаться на диагностику</button>
            </div>
          </div>
        </div>
      )}

      <!-- REPAIR OPTIONS / PRICES -->
      <div class="repair-section">
        <h2>Услуги по ремонту {transmission.name}</h2>
        <p class="section-subtitle">Стоимость основных работ — точная цена определяется после диагностики</p>
        <div class="repair-grid">
          {repairOptions.map((option, idx) => (
            <div class={`repair-card ${idx === repairOptions.length - 1 ? '' : ''}`}>
              <div class="repair-number">{(idx + 1).toString().padStart(2, '0')}</div>
              <h3>{option.name}</h3>
              <p>{option.desc}</p>
              <div class="repair-price">{option.price}</div>
              <button class="repair-btn" onclick="openQuickRequest()">Записаться</button>
            </div>
          ))}
        </div>
      </div>

      <!-- SERVICE CARDS GRID -->
      <div class="services-grid-section">
        <h2>Полный спектр работ с {transmission.name}</h2>
        <div class="services-grid">
          <div class="service-card">
            <img src="https://s3.regru.cloud/yanis-grek/transmission/service1.png" alt="Компьютерная диагностика" class="service-card-image" />
            <h3>Компьютерная диагностика</h3>
            <p>Полная диагностика на профессиональном оборудовании BMW ICOM A2+C с расшифровкой всех кодов ошибок</p>
          </div>
          <div class="service-card">
            <img src="https://s3.regru.cloud/yanis-grek/transmission/service2.png" alt="Ремонт и восстановление" class="service-card-image" />
            <h3>Ремонт и восстановление</h3>
            <p>Специализированный ремонт с заменой изношенных деталей оригинальными запчастями BMW</p>
          </div>
          <div class="service-card">
            <img src="https://s3.regru.cloud/yanis-grek/transmission/service3.png" alt="Замена масла и фильтра" class="service-card-image" />
            <h3>Замена масла и фильтра</h3>
            <p>Регулярное обслуживание с использованием оригинального масла BMW и фильтра-картера</p>
          </div>
          <div class="service-card">
            <img src="https://s3.regru.cloud/yanis-grek/transmission/service4.png" alt="Промывка и чистка" class="service-card-image" />
            <h3>Промывка и чистка</h3>
            <p>Профилактическая промывка гидравлической системы для продления ресурса коробки</p>
          </div>
        </div>
      </div>
    </div>

    <!-- GUARANTEE BLOCK -->
    <div class="guarantee-block">
      <div class="guarantee-inner">
        <div class="guarantee-item">
          <div class="guarantee-icon">12</div>
          <div class="guarantee-text">
            <strong>Гарантия 12 месяцев</strong>
            <span>на все виды работ и запчасти</span>
          </div>
        </div>
        <div class="guarantee-item">
          <div class="guarantee-icon">OEM</div>
          <div class="guarantee-text">
            <strong>Оригинальные запчасти BMW</strong>
            <span>или сертифицированные OEM</span>
          </div>
        </div>
        <div class="guarantee-item">
          <div class="guarantee-icon">BMW</div>
          <div class="guarantee-text">
            <strong>Специалисты BMW</strong>
            <span>10+ лет опыта с BMW</span>
          </div>
        </div>
        <div class="guarantee-item">
          <div class="guarantee-icon">0₽</div>
          <div class="guarantee-text">
            <strong>Без скрытых доплат</strong>
            <span>итоговая цена = цена в договоре</span>
          </div>
        </div>
      </div>
    </div>

    <DiscountsWrapper />
    <WhyUsWrapper />
    <ServicingWrapper />
    <NumbersWrapper />

    <!-- FAQ SECTION -->
    <div class="faq-section">
      <div class="faq-inner">
        <h2>Часто задаваемые вопросы</h2>
        <p class="faq-subtitle">Ответы на популярные вопросы о ремонте {transmission.name}</p>
        <div class="faq-list">
          {faqItems.map((item, idx) => (
            <details class="faq-item" open={idx === 0}>
              <summary class="faq-question">{item.q}</summary>
              <p class="faq-answer">{item.a}</p>
            </details>
          ))}
        </div>
        <div class="faq-cta">
          <p>Остались вопросы? Позвоните нам или запишитесь на бесплатную консультацию</p>
          <button class="faq-cta-btn" onclick="openQuickRequest()">Получить консультацию</button>
        </div>
      </div>
    </div>

    <AdvantagesWrapper />
  </div>
</Layout>

<style>
  .transmission-page {
    min-height: 100vh;
    margin-top: 90px;
  }

  /* HERO */
  .transmission-hero {
    background: linear-gradient(135deg, #e8e8e8 0%, #d0d0d0 100%);
    padding: 80px 20px 60px;
  }

  .transmission-hero-content {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .transmission-page[data-type='akpp'] .transmission-hero-content,
  .transmission-page[data-type='elektro'] .transmission-hero-content {
    grid-template-columns: 1fr;
  }

  .transmission-hero-left {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .transmission-type-badge {
    display: inline-block;
    background: #2b6eff;
    color: white;
    font-size: 13px;
    font-weight: 600;
    padding: 6px 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: fit-content;
  }

  .transmission-hero h1 {
    font-family: 'Russo One', sans-serif;
    font-size: 48px;
    color: #262626;
    margin: 0;
    text-transform: uppercase;
  }

  .transmission-models {
    font-size: 16px;
    color: #444;
    font-weight: 500;
    margin: 0;
  }

  .transmission-description {
    font-size: 18px;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .hero-price {
    background: #262626;
    color: white;
    padding: 14px 24px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-price-label {
    font-size: 12px;
    font-weight: 400;
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-price-value {
    font-size: 18px;
    font-weight: 700;
  }

  .hero-btn {
    padding: 16px 40px;
    background: black;
