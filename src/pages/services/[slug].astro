<script>
  function smoothScroll() {
    // Сначала пытаемся найти форму по id service-quiz (на этой же странице)
    let element = document.getElementById('service-quiz');
    
    // Если не найдена, пытаемся найти форму заявки (обычно это контактная форма)
    if (!element) {
      element = document.querySelector('[data-form-section]');
    }
    
    // Если всё ещё не найдена, пытаемся найти форму по классу или другому селектору
    if (!element) {
      element = document.getElementById('Form');
    }
    
    if (element) {
      element.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }
  
  // Глобальная функция для использования на других страницах
  (window as any).smoothScroll = smoothScroll;
  
  // Прикрепляем обработчик к кнопкам на странице
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.service-btn-booking, .cta-button');
    buttons.forEach(button => {
      button.addEventListener('click', smoothScroll);
    });
  });
</script>

