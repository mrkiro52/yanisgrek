const serviceData = allServices[slug as string];

if (!serviceData) {
  return Astro.redirect('/404');
}

const title = `${serviceData.title} - YanisGrek`;
const description = serviceData.description;
---

<Layout {title} {description}>
  <div class="service-page">
    <div class="service-hero">
      <div class="service-hero-content">
        <div class="service-hero-left">
          <h1>{serviceData.title}</h1>
          <p class="service-description">{serviceData.description}</p>
          <div class="service-hero-buttons">
            <div class="service-price">
              <span class="price-label">Стоимость:</span>
              <span class="price-value">{serviceData.price}</span>
            </div>
            <button class="service-btn-booking" onclick="openQuickRequest()">Записаться</button>
          </div>
        </div>
        <div 
          class="service-hero-image-placeholder"
          style={serviceData.mainphoto ? `background-image: url('${serviceData.mainphoto}'); background-size: cover; background-position: center;` : ''}
        ></div>
      </div>
    </div>

    <div class="service-content">
      <div class="service-about">
        <h2>Об услуге</h2>
        <p>{serviceData.content}</p>
      </div>

      <DiscountsWrapper />

      <ServiceStagesWrapper stages={serviceData.stages} />

      <div class="service-features">
        <h2>Что входит в услугу</h2>
        <ul class="features-list">
          {serviceData.features.map(feature => (
            <li>{feature}</li>
          ))}
        </ul>
      </div>

      <div class="service-cta">
        <button class="cta-button" onclick="openQuickRequest()">Записаться на услугу</button>
      </div>
    </div>

    {slug === 'remont-korobki-peredach' && (
      <section id="transmissions">
        <TransmissionSelectorWrapper />
      </section>
    )}

    {slug === 'remont-dvigatelya' && (
      <section id="engines">
        <EngineSelectorWrapper />
      </section>
    )}

    <WhyUsWrapper />
    <AdvantagesWrapper />
    <ServicingWrapper />
    <NumbersWrapper />
  </div>
</Layout>

<script>
  function openQuickRequest() {
