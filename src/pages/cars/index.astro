  // M серии
  { name: 'BMW M2', slug: 'bmw-m2', type: 'Спортивный купе', image: 'https://s3.regru.cloud/yanis-grek/cars/bmw-m.webp?response-content-disposition=attachment&AWSAccessKeyId=A34BKYHPZC4DLUPNMRCI&Signature=Wf5KiJrOQdy%2FUgjPZqcjnkRW934%3D&Expires=1776872917' },
  { name: 'BMW M3', slug: 'bmw-m3', type: 'Спортивный седан', image: 'https://s3.regru.cloud/yanis-grek/cars/bmw-m.webp?response-content-disposition=attachment&AWSAccessKeyId=A34BKYHPZC4DLUPNMRCI&Signature=Wf5KiJrOQdy%2FUgjPZqcjnkRW934%3D&Expires=1776872917' },
