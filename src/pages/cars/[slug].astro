const carData = carModels[slug as string];

if (!carData) {
  return Astro.redirect('/404');
}

const title = `Ремонт и обслуживание ${carData.title} - YanisGrek`;
const description = carData.description;
---

<Layout {title} {description}>
  <div class="car-page">
    <div class="car-hero">
      <div class="car-hero-container">
        <div class="car-hero-content">
          <h1>{carData.title}</h1>
          <p class="car-description">{carData.description}</p>
          <button class="hero-button" onclick="openQuickRequest()">Записаться</button>
        </div>
        {carData.imageUrl ? (
          <img src={carData.imageUrl} alt={carData.title} class="car-hero-image" />
        ) : (
          <div class="car-hero-image-placeholder"></div>
        )}
      </div>
    </div>

    <div class="car-content">
      <div class="car-about">
        <h2>О модели</h2>
        <p>{carData.about}</p>
      </div>

      <div class="car-services">
        <h2>Наши услуги для {carData.title}</h2>
        <ul class="services-list">
          {carData.services.map(service => (
            <li>{service}</li>
          ))}
        </ul>
      </div>

      <div class="car-cta">
        <a onclick="openQuickRequest()" class="cta-button" style="cursor: pointer;">Записаться на обслуживание</a>
      </div>
    </div>

    <WhyUsWrapper />
    <ChillZoneWrapper />
    <DiscountsWrapper />
    <ServicingWrapper />
    <NumbersWrapper />
  </div>
</Layout>

<script>
  function openQuickRequest() {
    window.dispatchEvent(new CustomEvent('openQuickRequest'));
  }
  (window as any).openQuickRequest = openQuickRequest;
</script>

