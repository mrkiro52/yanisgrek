const generationInfo = generationsData[slug]?.[slug2];

if (!generationInfo) {
  return Astro.redirect('/404');
}

const title = `${generationInfo.title} - Ремонт и обслуживание - YanisGrek`;
const description = `${generationInfo.description}`;
---

<Layout {title} {description}>
  <div class="generation-page">
    <div class="generation-hero">
      <div class="generation-hero-content">
        <h1>{generationInfo.title}</h1>
        <p class="generation-years">{generationInfo.years}</p>
        <p class="generation-description">{generationInfo.description}</p>
      </div>
    </div>

    <div class="generation-content">
      <div class="highlights-section">
        <h2>Характеристики поколения</h2>
        <div class="highlights-grid">
          {generationInfo.highlights.map(highlight => (
            <div class="highlight-item">
              <div class="highlight-icon">✓</div>
              <p>{highlight}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="services-section">
        <h2>Специализированное обслуживание</h2>
        <p>Наш сервис предоставляет полный спектр услуг по диагностике, ремонту и обслуживанию {generationInfo.title}. Мы используем оригинальные запчасти и современное оборудование для обеспечения высочайшего качества работ.</p>
        <a href="/#service-quiz" class="cta-button">Записаться на обслуживание</a>
      </div>
    </div>

    <WhyUsWrapper />
    <NumbersWrapper />
    <AdvantagesWrapper />
  </div>
</Layout>

<style>
  .generation-page {
    min-height: 100vh;
    margin-top: 90px;
  }

  .generation-hero {
    background: linear-gradient(135deg, #e8e8e8 0%, #d0d0d0 100%);
    padding: 80px 20px 60px;
  }

  .generation-hero-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .generation-hero h1 {
    font-family: 'Russo One', sans-serif;
    font-size: 48px;
    color: #262626;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .generation-years {
    font-size: 18px;
    color: #2b6eff;
    font-weight: 600;
    margin-bottom: 20px;
  }

  .generation-description {
    font-size: 18px;
    color: #666;
    line-height: 1.8;
    margin: 0;
  }

  .generation-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 20px;
  }

  .highlights-section {
    margin-bottom: 80px;
  }

  .highlights-section h2 {
    font-family: 'Helvetica', sans-serif;
    font-size: 32px;
    font-weight: 600;
    color: #262626;
    margin-bottom: 48px;
    text-align: center;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 60px;
  }

  .highlight-item {
    display: flex;
    gap: 16px;
    padding: 24px;
    background: rgb(245, 245, 245);
    border-radius: 8px;
    transition: all 0.3s;
  }

  .highlight-item:hover {
    background: rgb(235, 235, 235);
    transform: translateY(-4px);
  }

  .highlight-icon {
    width: 32px;
    height: 32px;
    background: #2b6eff;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
  }

  .highlight-item p {
    margin: 0;
    font-size: 16px;
    color: #262626;
    line-height: 1.6;
  }

  .services-section {
    text-align: center;
    padding: 60px 40px;
    background: rgb(245, 245, 245);
    border-radius: 12px;
  }

  .services-section h2 {
    font-family: 'Helvetica', sans-serif;
    font-size: 32px;
    font-weight: 600;
    color: #262626;
    margin-bottom: 24px;
  }

  .services-section p {
    font-size: 18px;
    color: #666;
    line-height: 1.8;
    margin-bottom: 32px;
  }

  .cta-button {
    display: inline-block;
    padding: 16px 48px;
    background: black;
    color: white;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.3s;
  }

  .cta-button:hover {
    background: #2b6eff;
  }

  @media (max-width: 1024px) {
    .highlights-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .generation-hero {
      padding: 60px 20px 40px;
    }

    .generation-hero h1 {
      font-size: 32px;
    }

    .generation-description {
      font-size: 16px;
    }

    .generation-content {
      padding: 60px 20px;
    }

    .highlights-section h2,
    .services-section h2 {
      font-size: 24px;
      margin-bottom: 32px;
    }

    .highlights-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .highlight-item {
      padding: 20px 16px;
    }

    .highlight-item p {
      font-size: 14px;
    }

    .services-section {
      padding: 40px 20px;
    }

    .services-section p {
      font-size: 16px;
    }

    .cta-button {
      width: 100%;
      padding: 14px 24px;
      font-size: 14px;
    }
  }

  @media (max-width: 480px) {
    .generation-page {
      margin-top: 70px;
    }

    .generation-hero h1 {
      font-size: 24px;
    }

    .generation-years {
      font-size: 14px;
    }

    .generation-description {
      font-size: 14px;
    }

    .highlight-item {
      gap: 12px;
      padding: 16px 12px;
    }

    .services-section {
      padding: 30px 15px;
    }
  }
</style>