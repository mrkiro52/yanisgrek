---
import Layout from '../../layouts/Layout.astro';
import ContactsHero from '../../components/ContactsHero.astro';
import ContactFormWrapper from '../../components/ContactFormWrapper.astro';
import WhyUsWrapper from '../../components/WhyUsWrapper.astro';
import DiscountsWrapper from '../../components/DiscountsWrapper.astro';
import NumbersWrapper from '../../components/NumbersWrapper.astro';

const title = 'Контакты YanisGrek - Техцентр BMW в Москве';
const description = 'Свяжитесь с техническим центром YanisGrek: адрес Высоковольтный проезд, 1, стр. 29 Москва, телефон +7 495 76 76 500. Профессиональный ремонт BMW, Mini Cooper, Rolls Royce. Пн-Пт: 10:00-20:00, Сб: 11:00-20:00 Вс: 11:00-18:00.';
---

<Layout {title} {description}>
  <div class="contacts-page">
    <ContactsHero />
    
    <section id="contact-form" class="contact-form-section">
      <div class="contact-form-wrapper">
        <ContactFormWrapper />
      </div>
    </section>

    <WhyUsWrapper />
    <DiscountsWrapper />
    <NumbersWrapper />
  </div>
</Layout>

<style>
  .contacts-page {
    width: 100%;
  }

  .contact-form-section {
    padding: 80px 20px;
    background: #f5f5f5;
  }

  .contact-form-wrapper {
    max-width: 1200px;
    margin: 0 auto;
  }
</style>