---
import Layout from '../layouts/Layout.astro';

const title = 'Страница не найдена - YanisGrek';
const description = 'Страница не найдена. Если вы потеряли нужную страницу, свяжитесь с нами и наш менеджер поможет вам.';
---

<Layout {title} {description}>
  <div class="error-page">
    <div class="error-container">
      <div class="error-content">
        <h1 class="error-code">404</h1>
        <h2 class="error-title">Страница не найдена</h2>
        <p class="error-description">
          К сожалению, страница, которую вы ищете, не существует, была удалена или перемещена.
        </p>

        <div class="error-info">
          <div class="info-card">
            <h3>Не нашли нужную страницу?</h3>
            <p>
              Не волнуйтесь! Если вы не нашли интересующую вас услугу или информацию, всегда можно обратиться к нам. 
              Наш менеджер свяжется с вами через <strong>15 минут</strong> и поможет найти нужное решение.
            </p>
          </div>
        </div>

        <div class="button-group">
          <a href="/" class="button button-primary">
            <span>На главную</span>
          </a>
          <button class="button button-secondary" onclick="callManager()">
            <span>Связаться с менеджером</span>
          </button>
        </div>

        <div class="help-text">
          <p>Или позвоните нам:</p>
          <a href="tel:+74957676500" class="phone-link">+7 495 76 76 500</a>
        </div>
      </div>

      <div class="error-image">
        <div class="error-illustration">
          <svg viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg">
            <!-- Большой круг с 404 -->
            <circle cx="150" cy="150" r="140" fill="none" stroke="#2b6eff" stroke-width="2" opacity="0.2"/>
            <circle cx="150" cy="150" r="100" fill="none" stroke="#2b6eff" stroke-width="2" opacity="0.3"/>
            
            <!-- Декоративные элементы -->
            <circle cx="80" cy="80" r="15" fill="#2b6eff" opacity="0.2"/>
            <circle cx="220" cy="220" r="15" fill="#2b6eff" opacity="0.2"/>
            <circle cx="220" cy="80" r="10" fill="#2b6eff" opacity="0.15"/>
            <circle cx="80" cy="220" r="10" fill="#2b6eff" opacity="0.15"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  function callManager() {
    window.dispatchEvent(new CustomEvent('openQuickRequest'));
  }
  (window as any).callManager = callManager;
</script>

<style>
  .error-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #f5f5f5 0%, #ffffff 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    margin-top: 90px;
  }

  .error-container {
    max-width: 1200px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .error-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .error-code {
    font-family: 'Russo One', sans-serif;
    font-size: 120px;
    font-weight: 700;
    color: #262626;
    margin: 0;
    line-height: 1;
    text-transform: uppercase;
  }

  .error-title {
    font-family: 'Helvetica', sans-serif;
    font-size: 36px;
    font-weight: 700;
    color: #262626;
    margin: 0;
    line-height: 1.2;
  }

  .error-description {
    font-family: 'Helvetica', sans-serif;
    font-size: 18px;
    color: #666;
    margin: 0;
    line-height: 1.6;
  }

  .error-info {
    background: white;
    border-left: 4px solid #2b6eff;
    padding: 24px;
    border-radius: 8px;
    margin: 24px 0;
  }

  .info-card h3 {
    font-family: 'Helvetica', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #262626;
    margin: 0 0 12px 0;
  }

  .info-card p {
    font-family: 'Helvetica', sans-serif;
    font-size: 16px;
    color: #666;
    margin: 0;
    line-height: 1.6;
  }

  .button-group {
    display: flex;
    gap: 16px;
    margin: 32px 0;
    flex-wrap: wrap;
  }

  .button {
    padding: 16px 32px;
    font-family: 'Helvetica', sans-serif;
    font-size: 16px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    border-radius: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    min-width: 200px;
  }

  .button-primary {
    background: #000;
    color: white;
  }

  .button-primary:hover {
    background: #2b6eff;
  }

  .button-secondary {
    background: transparent;
    color: #000;
    border: 2px solid #000;
  }

  .button-secondary:hover {
    background: #000;
    color: white;
  }

  .help-text {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
  }

  .help-text p {
    margin: 0;
    font-family: 'Helvetica', sans-serif;
    font-size: 16px;
    color: #666;
  }

  .phone-link {
    font-family: 'Helvetica', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #2b6eff;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .phone-link:hover {
    color: #000;
  }

  .error-image {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .error-illustration {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .error-illustration svg {
    width: 100%;
    height: 100%;
  }

  /* Мобильная версия */
  @media (max-width: 1024px) {
    .error-container {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .error-code {
      font-size: 80px;
    }

    .error-title {
      font-size: 28px;
    }

    .error-description {
      font-size: 16px;
    }

    .error-image {
      order: -1;
    }

    .error-illustration {
      max-width: 300px;
    }
  }

  @media (max-width: 768px) {
    .error-page {
      padding: 20px 20px;
      margin-top: 100px;
    }

    .error-image {
      display: none;
    }

    .error-code {
      font-size: 64px;
    }

    .error-title {
      font-size: 24px;
    }

    .error-description {
      font-size: 14px;
    }

    .button-group {
      flex-direction: column;
      gap: 12px;
    }

    .button {
      width: 100%;
      min-width: unset;
    }

    .help-text {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }

    .phone-link {
      font-size: 16px;
    }

    .info-card {
      padding: 16px;
      margin: 16px 0;
    }

    .info-card h3 {
      font-size: 16px;
    }

    .info-card p {
      font-size: 14px;
    }
  }

  @media (max-width: 480px) {
    .error-page {
      margin-top: 80px;
      padding: 16px 16px;
    }

    .error-code {
      font-size: 48px;
    }

    .error-title {
      font-size: 20px;
    }

    .error-description {
      font-size: 13px;
    }

    .button {
      padding: 14px 24px;
      font-size: 14px;
    }

    .error-illustration {
      max-width: 200px;
    }
  }
</style>
