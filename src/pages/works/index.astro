---
import Layout from '../../layouts/Layout.astro';
import NumbersWrapper from '../../components/NumbersWrapper.astro';
import WhyUsWrapper from '../../components/WhyUsWrapper.astro';
import AdvantagesWrapper from '../../components/AdvantagesWrapper.astro';
import ScrollArrow from '../../components/ScrollArrow.astro';

const title = 'Наши работы - YanisGrek';
const description = 'Портфолио выполненных работ и проектов нашей команды. Посмотрите примеры качественного ремонта BMW.';

const cases = [
  {
    id: 1,
    title: 'Полный ремонт АКПП BMW 5 Series',
    description: 'Диагностика, замена фильтра, промывка гидроблока, сброс адаптаций',
    image: 'https://s3.regru.cloud/yanis-grek/cases/case1.webp?response-content-disposition=attachment&AWSAccessKeyId=A34BKYHPZC4DLUPNMRCI&Signature=Z6fNSjCyGuBxe1TgiRNdi0kMbjY%3D&Expires=1776872173'
  },
  {
    id: 2,
    title: 'Замена цепи ГРМ BMW 3 Series',
    description: 'Замена цепи, натяжителей и направляющих, настройка фаз газораспределения',
    image: 'https://s3.regru.cloud/yanis-grek/cases/case2.webp?response-content-disposition=attachment&AWSAccessKeyId=A34BKYHPZC4DLUPNMRCI&Signature=sbd9MLdQOF81goBe6A0FXj%2FJz%2F0%3D&Expires=1776872166'
  },
  {
    id: 3,
    title: 'Ремонт рулевой рейки BMW X5',
    description: 'Замена уплотнений, сальников, регулировка люфта, калибровка',
    image: 'https://s3.regru.cloud/yanis-grek/cases/case3.webp?response-content-disposition=attachment&AWSAccessKeyId=A34BKYHPZC4DLUPNMRCI&Signature=DdkWmj8dgs%2BFNPDdDeMXD16YUtA%3D&Expires=1776872158'
  },
  {
    id: 4,
    title: 'Замена подвески BMW 7 Series',
    description: 'Замена амортизаторов, пружин, стабилизаторов, регулировка развал-схождения',
    image: 'https://s3.regru.cloud/yanis-grek/cases/case4.webp?response-content-disposition=attachment&AWSAccessKeyId=A34BKYHPZC4DLUPNMRCI&Signature=XwNf6ZvmHyT5igEnKhQne6qsuEY%3D&Expires=1776872149'
  },
  {
    id: 5,
    title: 'Диагностика BMW M4',
    description: 'Комплексная компьютерная диагностика спортивных систем',
    image: 'https://s3.regru.cloud/yanis-grek/cases/case5.webp?response-content-disposition=attachment&AWSAccessKeyId=A34BKYHPZC4DLUPNMRCI&Signature=9cpXZFZyU3ylJ%2BnMOmYn9rWrS1s%3D&Expires=1776872140'
  },
  {
    id: 6,
    title: 'Ремонт двигателя BMW X3',
    description: 'Замена масла, фильтров, проверка всех систем',
    image: 'https://s3.regru.cloud/yanis-grek/cases/case6.webp?response-content-disposition=attachment&AWSAccessKeyId=A34BKYHPZC4DLUPNMRCI&Signature=pCxV%2FAmo626B3JcshPOLFnPPqCo%3D&Expires=1776872134'
  },
  {
    id: 7,
    title: 'Обслуживание BMW 5 Series',
    description: 'Полное техническое обслуживание и чистка систем',
    image: 'https://s3.regru.cloud/yanis-grek/cases/case7.webp?response-content-disposition=attachment&AWSAccessKeyId=A34BKYHPZC4DLUPNMRCI&Signature=XbVnglQNLwOHGZWtf02A4ScmmmQ%3D&Expires=1776872126'
  },
  {
    id: 8,
    title: 'Сложный ремонт BMW i8',
    description: 'Диагностика и ремонт гибридной системы',
    image: 'https://s3.regru.cloud/yanis-grek/cases/case8.webp?response-content-disposition=attachment&AWSAccessKeyId=A34BKYHPZC4DLUPNMRCI&Signature=fZSCQQaI8%2FrdvYrEVEALwjh%2BPH4%3D&Expires=1776872036'
  }
];
---

<Layout {title} {description}>
  <section class="works-hero">
    <div class="works-hero-content">
      <h1>Наши работы</h1>
      <p class="works-subtitle">Портфолио и примеры выполненных работ нашей команды</p>
      
      <div class="company-info">
        <div class="company-info-item">
          <div class="info-label">Адрес</div>
          <div class="info-value">Москва Высоковольтный проезд, 1, стр. 29</div>
        </div>
        <div class="company-info-item">
          <div class="info-label">Телефон</div>
          <div class="info-value">+7 495 76 76 500</div>
        </div>
        <div class="company-info-item">
          <div class="info-label">Режим работы</div>
          <div class="info-value">Пн-Пт: 10:00-20:00, Сб: 11:00-20:00 Вс: 11:00-18:00</div>
        </div>
      </div>
      
      <button class="hero-button" onclick="openQuickRequest()">Записаться</button>
    </div>
    <ScrollArrow targetSelector=".cases-section" />
  </section>

  <section class="cases-section">
    <div class="cases-container">
      <h2 class="cases-title">Кейсы наших проектов</h2>
      <div class="cases-grid">
        {cases.map(caseItem => (
          <div class="case-card">
            <div class="case-image" style={`background-image: url('${caseItem.image}'); background-size: cover; background-position: center;`}>
            </div>
            <div class="case-content">
              <h3 class="case-title">{caseItem.title}</h3>
              <p class="case-description">{caseItem.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <NumbersWrapper />
  <WhyUsWrapper />
  <AdvantagesWrapper />
</Layout>

<script>
  function openQuickRequest() {
    window.dispatchEvent(new CustomEvent('openQuickRequest'));
  }
  (window as any).openQuickRequest = openQuickRequest;
</script>

<style>
  .works-hero {
    background: #111;
    color: #fff;
    padding: 0 20px;
    text-align: center;
    min-height: 100vh;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .works-hero-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .works-hero-content h1 {
    font-family: 'Russo One', sans-serif;
    font-size: 60px;
    color: #fff;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .works-hero-content p {
    font-size: 20px;
    color: #fff;
    line-height: 1.6;
    opacity: 0.85;
    margin-bottom: 32px;
  }

  .works-subtitle {
    font-size: 20px;
    color: #fff;
    line-height: 1.6;
    opacity: 0.85;
    margin-bottom: 32px;
  }

  .company-info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin: 40px 0 40px 0;
    background: rgba(255, 255, 255, 0.05);
    padding: 24px;
    border-radius: 8px;
  }

  .company-info-item {
    text-align: center;
  }

  .info-label {
    font-size: 12px;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    display: block;
  }

  .info-value {
    font-size: 16px;
    color: #fff;
    font-weight: 500;
  }

  .hero-button {
    padding: 16px 48px;
    background: white;
    color: black;
    border: none;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    font-family: 'Helvetica', sans-serif;
  }

  .hero-button:hover {
    background: #2b6eff;
    color: white;
  }

  .cases-section {
    background: white;
    padding: 100px 20px;
  }

  .cases-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .cases-title {
    font-family: 'Russo One', sans-serif;
    font-size: 40px;
    color: #262626;
    text-align: center;
    margin-bottom: 60px;
    text-transform: uppercase;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }

  .case-card {
    background: white;
    border: 1px solid rgba(208, 208, 208, 0.5);
    overflow: hidden;
    transition: all 0.3s;
    cursor: pointer;
  }

  .case-card:hover {
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.15);
    transform: translateY(-4px);
  }

  .case-image {
    width: 100%;
    height: 280px;
    overflow: hidden;
    background: rgb(208, 208, 208);
  }

  .case-content {
    padding: 24px;
  }

  .case-title {
    font-family: 'Helvetica', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #262626;
    margin: 0 0 12px 0;
    line-height: 1.4;
    display: none;
  }

  .case-description {
    font-size: 14px;
    color: #666;
    margin: 0;
    line-height: 1.6;
    display: none;
  }

  @media (max-width: 1024px) {
    .works-hero-content h1 {
      font-size: 48px;
    }

    .cases-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }

    .cases-title {
      font-size: 32px;
      margin-bottom: 48px;
    }
  }

  @media (max-width: 768px) {
    .works-hero {
      padding: 80px 20px 60px;
    }

    .works-hero-content h1 {
      font-size: 36px;
      margin-bottom: 12px;
    }

    .works-subtitle {
      font-size: 16px;
    }

    .company-info {
      grid-template-columns: 1fr;
      gap: 16px;
      margin: 24px 0 24px 0;
      padding: 16px;
    }

    .cases-section {
      padding: 60px 20px;
    }

    .cases-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .cases-title {
      font-size: 24px;
      margin-bottom: 36px;
    }

    .case-image {
      height: 200px;
    }

    .case-content {
      padding: 18px;
    }

    .case-title {
      font-size: 16px;
      margin-bottom: 8px;
    }

    .case-description {
      font-size: 13px;
    }
  }

  @media (max-width: 480px) {
    .works-hero {
      padding: 60px 15px 50px;
    }

    .works-hero-content h1 {
      font-size: 28px;
    }

    .works-subtitle {
      font-size: 14px;
    }

    .company-info {
      grid-template-columns: 1fr;
      gap: 12px;
      margin: 20px 0 20px 0;
      padding: 12px;
    }

    .info-label {
      font-size: 11px;
    }

    .info-value {
      font-size: 14px;
    }

    .cases-section {
      padding: 40px 15px;
    }

    .cases-title {
      font-size: 20px;
      margin-bottom: 24px;
    }

    .case-image {
      height: 160px;
    }

    .case-content {
      padding: 14px;
    }

    .case-title {
      font-size: 14px;
    }

    .case-description {
      font-size: 12px;
    }
  }
</style>