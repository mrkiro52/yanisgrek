---
import Layout from '../../layouts/Layout.astro';
import WhyUsWrapper from '../../components/WhyUsWrapper.astro';
import AdvantagesWrapper from '../../components/AdvantagesWrapper.astro';
import { engines, getEngineById } from '../../assets/engineData';

export async function getStaticPaths() {
  return engines.map(engine => ({
    params: { slug: engine.id }
  }));
}

const { slug } = Astro.params;
const engine = getEngineById(slug);

if (!engine) {
  return Astro.redirect('/404');
}

const title = `Ремонт ${engine.name} BMW - YanisGrek`;
const description = `${engine.description}`;
---

<Layout {title} {description}>
  <div class="engine-page">
    <div class="engine-hero">
      <div class="engine-hero-content">
        <h1>{engine.name}</h1>
        <p class="engine-type">Тип: {engine.type === 'benzine' ? 'Бензиновый двигатель' : engine.type === 'diesel' ? 'Дизельный двигатель' : 'Гибридный/Электрический'}</p>
        <p class="engine-models">{engine.models}</p>
        <p class="engine-description">{engine.description}</p>
      </div>
    </div>

    <div class="engine-content">
      <div class="highlights-section">
        <h2>Характеристики</h2>
        <div class="highlights-grid">
          {engine.highlights.map(highlight => (
            <div class="highlight-item">
              <div class="highlight-icon">✓</div>
              <p>{highlight}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="services-section">
        <h2>Специализированное обслуживание</h2>
        <p>Наш сервис предоставляет полный спектр услуг по диагностике, ремонту и обслуживанию двигателя {engine.name}. Мы используем оригинальные запчасти и современное оборудование для обеспечения высочайшего качества работ.</p>
        <a onclick="openQuickRequest()" class="cta-button" style="cursor: pointer;">Записаться на обслуживание</a>
      </div>
    </div>

    <WhyUsWrapper />
    <AdvantagesWrapper />
  </div>
</Layout>

<style>
  .engine-page {
    min-height: 100vh;
    margin-top: 90px;
  }

  .engine-hero {
    background: linear-gradient(135deg, #e8e8e8 0%, #d0d0d0 100%);
    padding: 80px 20px 60px;
  }

  .engine-hero-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .engine-hero h1 {
    font-family: 'Russo One', sans-serif;
    font-size: 48px;
    color: #262626;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .engine-type {
    font-size: 16px;
    color: #2b6eff;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .engine-models {
    font-size: 18px;
    color: #666;
    font-weight: 500;
    margin-bottom: 20px;
  }

  .engine-description {
    font-size: 18px;
    color: #666;
    line-height: 1.8;
    margin: 0;
  }

  .engine-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 20px;
  }

  .highlights-section {
    margin-bottom: 80px;
  }

  .highlights-section h2 {
    font-family: 'Helvetica', sans-serif;
    font-size: 32px;
    font-weight: 600;
    color: #262626;
    margin-bottom: 48px;
    text-align: center;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 60px;
  }

  .highlight-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 24px;
    background: rgb(245, 245, 245);
    text-align: center;
    transition: all 0.3s;
  }

  .highlight-item:hover {
    background: rgb(235, 235, 235);
    transform: translateY(-4px);
  }

  .highlight-icon {
    width: 40px;
    height: 40px;
    background: #2b6eff;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 20px;
  }

  .highlight-item p {
    margin: 0;
    font-size: 16px;
    color: #262626;
    line-height: 1.6;
  }

  .services-section {
    text-align: center;
    padding: 60px 40px;
    background: rgb(245, 245, 245);
  }

  .services-section h2 {
    font-family: 'Helvetica', sans-serif;
    font-size: 32px;
    font-weight: 600;
    color: #262626;
    margin-bottom: 24px;
  }

  .services-section p {
    font-size: 18px;
    color: #666;
    line-height: 1.8;
    margin-bottom: 32px;
  }

  .cta-button {
    display: inline-block;
    padding: 16px 48px;
    background: black;
    color: white;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
  }

  .cta-button:hover {
    background: #2b6eff;
  }

  @media (max-width: 1024px) {
    .highlights-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  @media (max-width: 768px) {
    .engine-hero {
      padding: 60px 20px 40px;
    }

    .engine-hero h1 {
      font-size: 32px;
    }

    .engine-description {
      font-size: 16px;
    }

    .engine-content {
      padding: 60px 20px;
    }

    .highlights-section h2,
    .services-section h2 {
      font-size: 24px;
      margin-bottom: 32px;
    }

    .highlights-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .highlight-item {
      padding: 16px 12px;
    }

    .highlight-item p {
      font-size: 14px;
    }

    .services-section {
      padding: 40px 20px;
    }

    .services-section p {
      font-size: 16px;
    }

    .cta-button {
      width: 100%;
      padding: 14px 24px;
      font-size: 14px;
    }
  }

  @media (max-width: 480px) {
    .engine-page {
      margin-top: 70px;
    }

    .engine-hero h1 {
      font-size: 24px;
    }

    .engine-type {
      font-size: 14px;
    }

    .engine-models {
      font-size: 14px;
    }

    .engine-description {
      font-size: 14px;
    }

    .highlights-grid {
      grid-template-columns: 1fr;
    }

    .highlight-item {
      padding: 12px 10px;
    }

    .services-section {
      padding: 30px 15px;
    }
  }
</style>

<script>
  function openQuickRequest() {
    window.dispatchEvent(new CustomEvent('openQuickRequest'));
  }
  (window as any).openQuickRequest = openQuickRequest;
</script>