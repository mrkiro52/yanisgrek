---
import Header from '../components/Header.astro';
import ContactFormWrapper from '../components/ContactFormWrapper.astro';
import YandexMapWrapper from '../components/YandexMapWrapper.astro';
import FooterWrapper from '../components/FooterWrapper.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = 'YanisGrek - Технический центр по ремонту BMW',
  description = 'Профессиональный ремонт BMW, диагностика и техническое обслуживание. Сертифицированное оборудование и опытная команда.',
  image = '/og-image.jpg'
} = Astro.props;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		
		<!-- Meta информация -->
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#000000" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />
		
		<!-- Preload критических шрифтов -->
		<link 
			rel="preload" 
			as="font" 
			type="font/woff2" 
			href="/fonts/Helvetica.woff2" 
			crossorigin 
		/>
		<link 
			rel="preload" 
			as="font" 
			type="font/woff2" 
			href="/fonts/RussoOne-Regular.woff2" 
			crossorigin 
		/>
		
		<title>{title}</title>
	</head>
	<body>
		<Header />
		<main class="main-content">
			<slot />
		</main>
		<ContactFormWrapper />
		<YandexMapWrapper />
		<FooterWrapper />
	</body>
</html>

<style>
	:global(html),
	:global(body) {
		margin: 0;
		width: 100%;
	}

	:global(.main-content) {
		/* Для стартового экрана без отступа */
	}
</style>
