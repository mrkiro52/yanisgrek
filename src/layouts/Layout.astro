---
import Header from '../components/Header.astro';
import ContactFormWrapper from '../components/ContactFormWrapper.astro';
import YandexMapWrapper from '../components/YandexMapWrapper.astro';
import FooterWrapper from '../components/FooterWrapper.astro';
import QuickRequestPopupWrapper from '../components/QuickRequestPopupWrapper.astro';
import '../styles/global.css';

import CallButton from '../components/CallButton.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = 'YanisGrek - Технический центр по ремонту BMW',
  description = 'Профессиональный ремонт BMW, диагностика и техническое обслуживание. Сертифицированное оборудование и опытная команда.',
  image = '/og-image.jpg'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		
		<!-- Meta информация -->
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#000000" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />
		
		<!-- Preload критических ресурсов -->
		<link 
			rel="preload" 
			as="font" 
			type="font/woff2" 
			href="/fonts/Helvetica.woff2" 
			crossorigin 
		/>
		<link 
			rel="preload" 
			as="font" 
			type="font/woff2" 
			href="/fonts/RussoOne-Regular.woff2" 
			crossorigin 
		/>
		
		<!-- Preload главного фонового изображения для LCP (только десктоп) -->
		<link 
			rel="preload" 
			as="image" 
			href="/images/mainbg.webp"
			media="(min-width: 769px)"
		/>
		
		<!-- Preload мобильного изображения -->
		<link 
			rel="preload" 
			as="image" 
			href="/images/mainimg.webp"
			media="(max-width: 768px)"
		/>

		<!-- Preconnect для внешних сервисов -->
		<link rel="preconnect" href="https://yandex.ru" />
		<link rel="preconnect" href="https://api.telegram.org" />
		<link rel="dns-prefetch" href="https://yandex.ru" />
		<link rel="dns-prefetch" href="https://api.telegram.org" />
		
		<!-- Critical inline CSS для LCP -->
		<style>
			html,body{margin:0;width:100%;overflow-x:hidden}
			body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;background:#fff;color:#333}
			.startscreen{position:relative;width:100%;height:100vh;display:flex;overflow:hidden}
			.startscreen-bg{position:absolute;top:0;left:0;width:100%;height:100%;z-index:0}
			.startscreen-bg img{width:100%;height:100%;object-fit:cover}
			.header{position:fixed;top:0;left:0;width:100%;height:90px;background-color:rgba(0,0,0,.65);backdrop-filter:blur(5px);z-index:100}
		</style>
		
		<title>{title}</title>
	</head>
	<body>
			<Header />
			<main class="main-content">
				<slot />
			</main>
			<ContactFormWrapper />
			<YandexMapWrapper />
			<FooterWrapper />
			<CallButton />
			<QuickRequestPopupWrapper />
	</body>
</html>

<style>
	:global(html),
	:global(body) {
		margin: 0;
		width: 100%;
	}

	:global(.main-content) {
		/* Для стартового экрана без отступа */
	}
</style>
