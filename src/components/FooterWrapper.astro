---
import Footer from './Footer';
---

<Footer client:load />

<style>
:global(.Footer) {
  width: 100%;
}

:global(.footer-main) {
  background: black;
  padding: 60px 20px;
}

:global(.footer-container) {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 60px;
}

:global(.footer-column) {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

:global(.footer-logo) {
  width: 183px;
  height: 20px;
}

:global(.footer-desc) {
  font-size: 16px;
  color: white;
  line-height: 1.6;
}

:global(.footer-info) {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

:global(.footer-info p) {
  font-size: 14px;
  color: white;
  margin: 0;
  line-height: 1.6;
}

:global(.footer-info p a) {
  color: white;
  text-decoration: none;
  transition: opacity 0.3s;
}

:global(.footer-info p a:hover) {
  opacity: 0.7;
}

:global(.footer-column h3) {
  font-family: 'Russo One', sans-serif;
  font-size: 20px;
  color: white;
  text-transform: uppercase;
  margin: 0;
}

:global(.footer-links) {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

:global(.footer-links li a) {
  font-size: 14px;
  color: white;
  text-decoration: none;
  transition: opacity 0.3s;
}

:global(.footer-links li a:hover) {
  opacity: 0.7;
}

:global(.footer-bottom) {
  background: #262626;
  padding: 20px;
}

:global(.footer-bottom .footer-container) {
  display: flex;
  justify-content: space-between;
  align-items: center;
  grid-template-columns: 1fr;
}

:global(.footer-copyright) {
  font-size: 14px;
  color: white;
  margin: 0;
}

:global(.footer-social) {
  display: flex;
  gap: 12px;
  align-items: center;
}

:global(.footer-social a) {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.3s;
}

:global(.footer-social a:hover) {
  opacity: 0.7;
}

:global(.footer-social svg) {
  display: block;
}

@media screen and (max-width: 1024px) {
  :global(.footer-main) {
    padding: 40px 20px;
  }

  :global(.footer-container) {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  :global(.footer-bottom .footer-container) {
    flex-direction: column;
    gap: 20px;
    text-align: center;
  }
}

@media screen and (max-width: 768px) {
  :global(.footer-main) {
    padding: 32px 20px;
  }

  :global(.footer-container) {
    gap: 32px;
  }

  :global(.footer-column h3) {
    font-size: 18px;
  }

  :global(.footer-desc),
  :global(.footer-links li a) {
    font-size: 13px;
  }

  :global(.footer-info p) {
    font-size: 13px;
  }

  :global(.footer-copyright) {
    font-size: 12px;
  }

  :global(.footer-social) {
    gap: 8px;
  }

  :global(.footer-social svg) {
    width: 32px;
    height: 32px;
  }
}
</style>
