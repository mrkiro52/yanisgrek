---
import AboutTeam from './AboutTeam';
---

<AboutTeam client:visible />

<style>
  :global(.about-team) {
    background: #fff;
    padding: 100px 20px;
  }

  :global(.about-team__container) {
    max-width: 1200px;
    margin: 0 auto;
  }

  :global(.about-team__title) {
    font-family: 'Russo One', sans-serif;
    font-size: 40px;
    color: #262626;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 16px;
  }

  :global(.about-team__subtitle) {
    font-size: 18px;
    color: #666;
    text-align: center;
    margin-bottom: 60px;
  }

  :global(.about-team__slider) {
    position: relative;
    margin-bottom: 40px;
  }

  :global(.about-team__slider-track) {
    display: flex;
    gap: 24px;
    overflow: hidden;
    position: relative;
  }

  :global(.about-team__slide) {
    flex: 0 0 calc(25% - 18px);
    opacity: 0.5;
    transition: all 0.3s ease;
    transform: scale(0.9);
  }

  :global(.about-team__slide.active) {
    opacity: 1;
    transform: scale(1);
  }

  :global(.about-team__card) {
    background: linear-gradient(135deg, #f9f9f9 0%, #f5f5f5 100%);
    padding: 32px 24px;
    text-align: center;
    border: 2px solid transparent;
    transition: all 0.3s ease;
  }

  :global(.about-team__slide.active .about-team__card) {
    border-color: #2b6eff;
    background: linear-gradient(135deg, #fff 0%, #f9f9f9 100%);
    box-shadow: 0 10px 40px rgba(43, 110, 255, 0.1);
  }

  :global(.about-team__image-placeholder) {
    width: 100%;
    aspect-ratio: 1;
    background: #d0d0d0;
    margin-bottom: 20px;
  }

  :global(.about-team__image) {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    margin-bottom: 20px;
    display: block;
  }

  :global(.about-team__name) {
    font-family: 'Russo One', sans-serif;
    font-size: 18px;
    color: #262626;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  :global(.about-team__role) {
    font-size: 14px;
    color: #262626;
    font-weight: 600;
  }

  :global(.about-team__button) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    background: #262626;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
  }

  :global(.about-team__button:hover) {
    background: #2b6eff;
    transform: translateY(-50%) scale(1.1);
  }

  :global(.about-team__button--prev) {
    left: -70px;
  }

  :global(.about-team__button--next) {
    right: -70px;
  }

  :global(.about-team__dots) {
    display: flex;
    justify-content: center;
    gap: 12px;
  }

  :global(.about-team__dot) {
    width: 12px;
    height: 12px;
    background: #d0d0d0;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  :global(.about-team__dot.active) {
    background: #2b6eff;
    width: 36px;
  }

  @media (max-width: 1280px) {
    :global(.about-team) {
      padding: 90px 40px;
    }

    :global(.about-team__title) {
      font-size: 36px;
    }

    :global(.about-team__slide) {
      flex: 0 0 calc(25% - 18px);
    }

    :global(.about-team__button--prev) {
      left: -60px;
    }

    :global(.about-team__button--next) {
      right: -60px;
    }
  }

  @media (max-width: 1024px) {
    :global(.about-team__slide) {
      flex: 0 0 calc(33.333% - 16px);
    }

    :global(.about-team__title) {
      font-size: 32px;
    }

    :global(.about-team__button--prev) {
      left: -55px;
    }

    :global(.about-team__button--next) {
      right: -55px;
    }
  }

  @media (max-width: 768px) {
    :global(.about-team) {
      padding: 60px 20px;
    }

    :global(.about-team__title) {
      font-size: 24px;
    }

    :global(.about-team__slide) {
      flex: 0 0 calc(50% - 12px);
    }

    :global(.about-team__card) {
      padding: 24px 16px;
    }

    :global(.about-team__button--prev) {
      left: -40px;
    }

    :global(.about-team__button--next) {
      right: -40px;
    }
  }

  @media (max-width: 480px) {
    :global(.about-team__slide) {
      flex: 0 0 100%;
    }

    :global(.about-team__button--prev) {
      left: 0;
      top: auto;
      bottom: -60px;
      transform: none;
    }

    :global(.about-team__button--next) {
      right: 0;
      top: auto;
      bottom: -60px;
      transform: none;
    }

    :global(.about-team__button:hover) {
      transform: scale(1.1);
    }

    :global(.about-team__dots) {
      margin-top: 80px;
    }
  }
</style>
