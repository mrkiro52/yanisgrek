---
import Advantages from './Advantages';
---

<Advantages client:load />

<style>
:global(.Advantages) {
  background-color: white;
  padding: 80px 20px;
  display: flex;
  justify-content: center;
}

:global(.advantages-list) {
  width: 100%;
  max-width: 1200px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
}

:global(.advantage-item) {
  background: white;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: all 0.3s;
}

:global(.advantage-item:hover) {
  transform: translateY(-8px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
}

:global(.advantage-image) {
  width: 100%;
  height: 300px;
  overflow: hidden;
}

:global(.advantage-image img) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: all 0.3s;
}

:global(.advantage-item:hover .advantage-image img) {
  transform: scale(1.05);
}

:global(.advantage-text) {
  padding: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 120px;
}

:global(.advantage-text p) {
  font-family: 'Helvetica', sans-serif;
  font-size: 18px;
  color: #262626;
  line-height: 1.6;
  text-align: center;
  margin: 0;
  font-weight: 500;
}

@media screen and (max-width: 1024px) {
  :global(.Advantages) {
    padding: 60px 20px;
  }

  :global(.advantages-list) {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  :global(.advantage-image) {
    height: 250px;
  }

  :global(.advantage-text) {
    padding: 24px;
    min-height: 100px;
  }

  :global(.advantage-text p) {
    font-size: 16px;
  }
}

@media screen and (max-width: 768px) {
  :global(.Advantages) {
    padding: 40px 20px;
  }

  :global(.advantages-list) {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  :global(.advantage-image) {
    height: 200px;
  }

  :global(.advantage-text) {
    padding: 20px;
    min-height: auto;
  }

  :global(.advantage-text p) {
    font-size: 15px;
  }
}
</style>
