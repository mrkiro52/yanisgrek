---
import YandexMap from './YandexMap';
---

<YandexMap client:visible />

<style>
:global(.yandex_map) {
  width: 100%;
  height: 500px;
  position: relative;
}

:global(.yandex_map iframe) {
  display: block;
}

@media screen and (max-width: 1024px) {
  :global(.yandex_map) {
    height: 450px;
  }
}

@media screen and (max-width: 768px) {
  :global(.yandex_map) {
    height: 400px;
  }
}
</style>
