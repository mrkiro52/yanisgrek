---
// Компонент стартового экрана для страницы Контакты
import ScrollArrow from './ScrollArrow.astro';
---

<section class="contacts-hero">
  <div class="contacts-hero-content">
    <h1 class="contacts-hero-title">Свяжитесь с нами</h1>
    <p class="contacts-hero-subtitle">Технический центр по ремонту BMW, Mini Cooper и Rolls Royce</p>
    
    <div class="contacts-info">
      <div class="contact-item">
        <h3 class="contact-label">Адрес</h3>
        <p class="contact-value">Москва Высоковольтный проезд, 1, стр. 29</p>
      </div>
      <div class="contact-item">
        <h3 class="contact-label">Телефон</h3>
        <a href="tel:+74957676500" class="contact-value phone-link">+7 495 76 76 500</a>
      </div>
      <div class="contact-item">
        <h3 class="contact-label">Режим работы</h3>
        <p class="contact-value">Пн-Пт: 10:00-20:00<br/>Сб: 11:00-20:00 Вс: 11:00-18:00</p>
      </div>
    </div>

    <button class="contact-button" id="contactButton">Связаться</button>
    
    <ScrollArrow targetSelector=".ContactForm" />
  </div>
</section>

<script>
  const contactButton = document.getElementById('contactButton');
  if (contactButton) {
    contactButton.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('openQuickRequest'));
    });
  }
</script>

<style>
  .contacts-hero {
    width: 100%;
    min-height: 100vh;
    background: linear-gradient(135deg, #262626 0%, #1a1a1a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 80px 20px;
  }

  .contacts-hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 40px;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .contacts-hero-title {
    font-family: 'Russo One', sans-serif;
    font-size: 80px;
    color: white;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 2px;
    line-height: 1.1;
  }

  .contacts-hero-subtitle {
    font-size: 24px;
    color: #2b6eff;
    margin: 0;
    font-weight: 600;
  }

  .contacts-info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    padding: 40px;
    border-radius: 12px;
    backdrop-filter: blur(10px);
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .contact-label {
    font-size: 12px;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
    font-weight: 600;
  }

  .contact-value {
    font-size: 16px;
    color: #fff;
    margin: 0;
    line-height: 1.5;
  }

  .phone-link {
    text-decoration: none;
    color: #2b6eff;
    transition: color 0.3s;
  }

  .phone-link:hover {
    color: #fff;
  }

  .contact-button {
    padding: 16px 48px;
    background: #2b6eff;
    color: white;
    border: none;
    font-size: 16px;
    font-weight: 600;
    border-radius: 0;
    cursor: pointer;
    transition: all 0.3s;
    font-family: 'Helvetica', sans-serif;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .contact-button:hover {
    background: #1e4fbf;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(43, 110, 255, 0.3);
  }

  .contact-button:active {
    transform: translateY(0);
  }

  @media (max-width: 1280px) {
    .contacts-hero-title {
      font-size: 72px;
    }

    .contacts-hero-subtitle {
      font-size: 22px;
    }

    .contacts-info {
      gap: 25px;
      padding: 35px;
    }

    .contact-button {
      padding: 14px 40px;
      font-size: 15px;
    }
  }

  @media (max-width: 1024px) {
    .contacts-hero-title {
      font-size: 64px;
    }

    .contacts-hero-subtitle {
      font-size: 20px;
    }

    .contacts-info {
      gap: 25px;
      padding: 30px;
    }

    .contact-button {
      padding: 14px 40px;
    }
  }

  @media (max-width: 768px) {
    .contacts-hero {
      padding: 60px 20px;
      min-height: auto;
    }

    .contacts-hero-content {
      gap: 30px;
    }

    .contacts-hero-title {
      font-size: 48px;
    }

    .contacts-hero-subtitle {
      font-size: 18px;
    }

    .contacts-info {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 24px;
    }

    .contact-label {
      font-size: 11px;
    }

    .contact-value {
      font-size: 15px;
    }

    .contact-button {
      padding: 12px 32px;
      font-size: 14px;
    }
  }

  @media (max-width: 480px) {
    .contacts-hero {
      padding: 50px 16px;
    }

    .contacts-hero-content {
      gap: 24px;
    }

    .contacts-hero-title {
      font-size: 36px;
      letter-spacing: 1px;
    }

    .contacts-hero-subtitle {
      font-size: 16px;
    }

    .contacts-info {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 20px;
    }

    .contact-label {
      font-size: 10px;
    }

    .contact-value {
      font-size: 14px;
    }

    .contact-button {
      padding: 10px 28px;
      font-size: 13px;
    }

    .scroll-arrow {
      bottom: 20px;
    }

    .scroll-arrow svg {
      width: 20px;
      height: 20px;
    }
  }
</style>
