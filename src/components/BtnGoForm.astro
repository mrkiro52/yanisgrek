---
// Компонент кнопки "Оставить заявку"
---

<button class="btn-go-form" id="btn-go-form">
  Оставить заявку
</button>

<script>
  const button = document.getElementById('btn-go-form');
  if (button) {
    button.addEventListener('click', () => {
      // Диспатчим событие для открытия попапа
      window.dispatchEvent(new CustomEvent('openQuickRequest'));
    });
  }
</script>

<style>
  .btn-go-form {
    padding: 16px 32px;
    background-color: transparent;
    color: #fff;
    border: 2px solid #fff;
    border-radius: 0;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: none;
    font-family: 'Helvetica', sans-serif;
  }
</style>
