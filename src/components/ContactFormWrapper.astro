---
import ContactForm from './ContactForm';
---

<div id="Form" data-form-section>
  <ContactForm client:load />
</div>

<style>
:global(.ContactForm) {
  padding: 80px 20px;
  display: flex;
  justify-content: center;
  position: relative;
}

:global(.contact-content) {
  width: 100%;
  max-width: 1200px;
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
}

:global(.contact-left) {
  display: flex;
  flex-direction: column;
  gap: 40px;
}

:global(.contact-title) {
  font-family: 'Russo One', sans-serif;
  font-size: 36px;
  color: white;
  text-align: left;
  margin-bottom: 0;
  text-transform: uppercase;
  line-height: 1.2;
}

:global(.contact-form) {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 2px solid white;
  padding: 24px;
}

:global(.form-row) {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 24px;
  margin-bottom: 24px;
  align-items: start;
}

:global(.form-label) {
  font-family: 'Helvetica', sans-serif;
  font-size: 18px;
  color: white;
  font-weight: 500;
  padding-top: 12px;
}

:global(.form-input-wrapper) {
  display: flex;
  flex-direction: column;
  gap: 8px;
  position: relative;
}

:global(.datetime-wrapper) {
  position: relative;
}

:global(.calendar-icon) {
  position: absolute;
  right: 12px;
  top: 12px;
  color: #666;
  pointer-events: none;
  z-index: 1;
}

:global(.form-input) {
  width: 100%;
  padding: 12px 16px;
  font-size: 16px;
  background: white;
  border: 2px solid transparent;
  outline: none;
  font-family: 'Helvetica', sans-serif;
  transition: all 0.3s;
}

:global(.form-input:focus) {
  border-color: white;
  outline: none;
}

:global(.form-input.error) {
  border-color: #ff4444;
}

:global(.error-message) {
  color: #ff4444;
  font-size: 14px;
  font-family: 'Helvetica', sans-serif;
}

:global(.form-input[type="datetime-local"]::-webkit-calendar-picker-indicator) {
  opacity: 0;
  cursor: pointer;
  width: 100%;
  height: 100%;
  position: absolute;
  left: 0;
  top: 0;
}

:global(.form-submit) {
  width: 100%;
  padding: 20px;
  background: black;
  color: white;
  font-size: 18px;
  font-weight: 600;
  border: none;
  cursor: pointer;
  font-family: 'Helvetica', sans-serif;
  transition: all 0.3s;
  margin-top: 16px;
}

:global(.form-submit:hover) {
  background: #2b6eff;
}

:global(.contact-info) {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}

:global(.info-card) {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 2px solid white;
  padding: 16px;
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

:global(.info-card h3) {
  font-family: 'Russo One', sans-serif;
  font-size: 18px;
  color: white;
  margin-bottom: 0;
  font-weight: 400;
  text-transform: uppercase;
}

:global(.info-card p) {
  font-size: 14px;
  color: white;
  line-height: 1.6;
  margin: 0;
}

@media screen and (max-width: 1024px) {
  :global(.ContactForm) {
    padding: 60px 20px;
  }

  :global(.contact-content) {
    grid-template-columns: 1fr;
    gap: 32px;
  }

  :global(.contact-title) {
    font-size: 32px;
  }

  :global(.contact-form) {
    padding: 24px;
  }  :global(.form-row) {
    grid-template-columns: 160px 1fr;
    gap: 16px;
  }

  :global(.form-label) {
    font-size: 16px;
  }

  :global(.contact-info) {
    grid-template-columns: 1fr;
    gap: 16px;
  }
}

@media screen and (max-width: 768px) {
  :global(.ContactForm) {
    padding: 40px 20px;
  }

  :global(.contact-content) {
    gap: 24px;
  }

  :global(.contact-title) {
    font-size: 24px;
  }

  :global(.contact-form) {
    padding: 20px;
  }  :global(.form-row) {
    grid-template-columns: 1fr;
    gap: 8px;
    margin-bottom: 20px;
  }

  :global(.form-label) {
    font-size: 16px;
    padding-top: 0;
  }

  :global(.form-input) {
    padding: 12px;
    font-size: 15px;
  }

  :global(.form-submit) {
    padding: 16px;
    font-size: 16px;
  }

  :global(.info-card) {
    padding: 12px;
  }

  :global(.info-card h3) {
    font-size: 20px;
    margin-bottom: 12px;
  }

  :global(.info-card p) {
    font-size: 14px;
  }
}
</style>
