---
import ChillZone from './ChillZone';
---

<ChillZone client:load />

<style>
:global(.ChillZone) {
  background-color: rgb(208, 208, 208);
  padding: 80px 20px;
  display: flex;
  justify-content: center;
}

:global(.chillzone-content) {
  width: 100%;
  max-width: 1200px;
  display: flex;
  flex-direction: column;
  gap: 40px;
}

:global(.chillzone-text) {
  text-align: center;
}

:global(.chillzone-title) {
  font-family: 'Russo One', sans-serif;
  font-size: 32px;
  color: #262626;
  margin-bottom: 20px;
  text-transform: uppercase;
}

:global(.chillzone-description) {
  font-size: 18px;
  color: #666;
  line-height: 1.6;
  max-width: 800px;
  margin: 0 auto;
}

:global(.chillzone-gallery) {
  display: grid;
  grid-template-columns: 600px 600px;
  gap: 24px;
  width: 100%;
  max-width: 1224px;
  margin: 0 auto;
}

:global(.gallery-left) {
  width: 600px;
  height: 600px;
  position: relative;
}

:global(.gallery-left .image-wrapper) {
  width: 100%;
  height: 100%;
}

:global(.gallery-right) {
  display: flex;
  flex-direction: column;
  gap: 24px;
  width: 600px;
  height: 600px;
}

:global(.gallery-top) {
  width: 600px;
  height: 288px;
}

:global(.gallery-bottom) {
  width: 600px;
  height: 288px;
  display: grid;
  grid-template-columns: 288px 288px;
  gap: 24px;
}

:global(.image-wrapper) {
  width: 100%;
  height: 100%;
  overflow: hidden;
  position: relative;
}

:global(.image-wrapper img) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s;
}

:global(.image-wrapper:hover img) {
  transform: scale(1.05);
}

@media screen and (max-width: 1024px) {
  :global(.ChillZone) {
    padding: 60px 20px;
  }

  :global(.chillzone-title) {
    font-size: 28px;
  }

  :global(.chillzone-description) {
    font-size: 16px;
  }

  :global(.chillzone-gallery) {
    gap: 20px;
  }

  :global(.gallery-right) {
    gap: 20px;
  }

  :global(.gallery-bottom) {
    gap: 20px;
  }
}

@media screen and (max-width: 768px) {
  :global(.ChillZone) {
    padding: 40px 20px;
  }

  :global(.chillzone-content) {
    gap: 32px;
  }

  :global(.chillzone-title) {
    font-size: 24px;
    margin-bottom: 16px;
  }

  :global(.chillzone-description) {
    font-size: 15px;
  }

  :global(.chillzone-gallery) {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  :global(.gallery-right) {
    gap: 16px;
  }

  :global(.gallery-bottom) {
    gap: 16px;
  }
}
</style>
