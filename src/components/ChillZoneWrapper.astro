---
import ChillZone from './ChillZone';
---

<ChillZone client:visible />

<style>
:global(.ChillZone) {
  background-color: rgb(208, 208, 208);
  padding: 80px 20px;
  display: flex;
  justify-content: center;
}

:global(.chillzone-content) {
  width: 100%;
  max-width: 1200px;
  display: flex;
  flex-direction: column;
  gap: 40px;
}

:global(.chillzone-text) {
  text-align: center;
}

:global(.chillzone-title) {
  font-family: 'Russo One', sans-serif;
  font-size: 32px;
  color: #262626;
  margin-bottom: 20px;
  text-transform: uppercase;
}

:global(.chillzone-description) {
  font-size: 18px;
  color: #666;
  line-height: 1.6;
  max-width: 800px;
  margin: 0 auto;
}

:global(.chillzone-gallery) {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
}

:global(.image-wrapper) {
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
  position: relative;
}

:global(.image-wrapper img) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s;
}

:global(.image-wrapper:hover img) {
  transform: scale(1.05);
}

@media screen and (max-width: 1024px) {
  :global(.ChillZone) {
    padding: 60px 20px;
  }

  :global(.chillzone-title) {
    font-size: 28px;
  }

  :global(.chillzone-description) {
    font-size: 16px;
  }

  :global(.chillzone-gallery) {
    gap: 20px;
  }

  :global(.gallery-right) {
    gap: 20px;
  }

  :global(.gallery-bottom) {
    gap: 20px;
  }
}

@media screen and (max-width: 768px) {
  :global(.ChillZone) {
    padding: 40px 20px;
  }

  :global(.chillzone-content) {
    gap: 32px;
  }

  :global(.chillzone-title) {
    font-size: 24px;
    margin-bottom: 16px;
  }

  :global(.chillzone-description) {
    font-size: 15px;
  }

  :global(.chillzone-gallery) {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  :global(.gallery-left) {
    width: 100%;
  }

  :global(.gallery-left .image-wrapper) {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    position: relative;
  }

  :global(.gallery-left .image-wrapper img) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.gallery-right) {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  :global(.gallery-top) {
    width: 100%;
  }

  :global(.gallery-top .image-wrapper) {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    position: relative;
  }

  :global(.gallery-top .image-wrapper img) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.gallery-bottom) {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  :global(.gallery-bottom .image-wrapper) {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    position: relative;
  }

  :global(.gallery-bottom .image-wrapper img) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
}
</style>
