---
import BtnGoCalc from './BtnGoCalc.astro';
import BtnGoForm from './BtnGoForm.astro';
---

<div class="startscreen">
  <div class="startscreen-bg">
    <picture>
      <source media="(max-width: 768px)" srcset="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" />
      <img
        src="/images/mainbg.webp"
        alt="Фоновое изображение технического центра YanisGrek"
        loading="lazy"
        width="1920"
        height="1080"
      />
    </picture>
  </div>
  <div class="startscreen-wrapper">
    <div class="startscreen-content">
      <div class="mobile-car-image-wrapper">
        <img 
          src="/images/mainimg.webp" 
          alt="BMW автомобиль" 
          class="mobile-car-image"
          loading="lazy"
        />
      </div>
      <div class="left-block">
        <img
          src="/images/techCenter.webp"
          alt="Логотип YANIS GREK - Технический центр по ремонту BMW"
          width="374"
          height="104"
          loading="eager"
          fetchpriority="high"
        />
        <div class="buttons">
          <BtnGoCalc />
          <BtnGoForm />
        </div>
      </div>
      <div class="text-block">
        <p>
          Сертифицированное оборудование, фирменный инструмент и опыт команды —
          для быстрого и качественного ремонта.
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .startscreen {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background-color: #000000;
  }

  .startscreen-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: 0;
    animation: fadeInBackground 0.8s ease-in-out 1s forwards;
  }

  @keyframes fadeInBackground {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .startscreen-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mobile-car-image-wrapper {
    display: none;
  }

  .mobile-car-image {
    display: none;
  }

  .startscreen-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0 20px 60px;
  }

  .startscreen-content {
    max-width: 1200px;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 60px;
  }

  .left-block {
    display: flex;
    flex-direction: column;
    gap: 40px;
    max-width: 374px;
    opacity: 0;
    transform: translateX(-100px);
    animation: slideInLeft 0.8s ease-out 0.3s forwards;
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-100px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .left-block img {
    width: 100%;
    height: auto;
  }

  .buttons {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
  }

  .buttons :global(button) {
    width: 100%;
  }

  .text-block {
    max-width: 600px;
    text-align: right;
    opacity: 0;
    transform: translateX(100px);
    animation: slideInRight 0.8s ease-out 0.5s forwards;
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(100px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .text-block p {
    font-size: 24px;
    line-height: 1.3;
    color: #fff;
    font-family: 'Russo One', sans-serif;
    text-transform: uppercase;
    opacity: 0.8;
  }

  @media (max-width: 1280px) {
    .startscreen-wrapper {
      padding: 0 40px 60px;
    }

    .startscreen-content {
      gap: 50px;
    }

    .text-block p {
      font-size: 22px;
    }
  }

  @media (max-width: 1024px) {
    .startscreen-wrapper {
      padding: 0 30px 60px;
    }

    .startscreen-content {
      gap: 40px;
    }

    .text-block p {
      font-size: 20px;
    }
  }

  @media (max-width: 768px) {
    .startscreen {
      background-color: #000000;
    }

    .startscreen-bg {
      display: none;
    }

    .mobile-car-image-wrapper {
      display: block;
      width: 100%;
      aspect-ratio: auto;
      background-color: transparent;
      margin-bottom: 0;
      overflow: visible;
    }

    .mobile-car-image {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
      opacity: 0;
      animation: fadeInMobileImage 0.8s ease-in-out 1s forwards;
    }

    @keyframes fadeInMobileImage {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    .startscreen-wrapper {
      padding: 0 20px 60px;
    }

    .startscreen-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 40px;
    }

    .left-block {
      max-width: 100%;
      animation: slideInLeft 0.8s ease-out 0.3s forwards;
    }

    .text-block {
      max-width: 100%;
      animation: slideInRight 0.8s ease-out 0.5s forwards;
    }

    .text-block p {
      font-size: 16px;
    }
  }
</style>
