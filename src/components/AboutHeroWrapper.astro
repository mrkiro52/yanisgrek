---
import AboutHero from './AboutHero';
---

<AboutHero client:load />

<style>
  :global(.about-hero) {
    background: url('/src/assets/images/aboutbg.webp') center / cover no-repeat;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 20px;
    margin-top: 0;
    padding-top: 90px;
  }

  :global(.about-hero)::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1;
  }

  :global(.about-hero__content) {
    max-width: 800px;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  :global(.about-hero__title) {
    font-family: 'Russo One', sans-serif;
    font-size: 56px;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  :global(.about-hero__subtitle) {
    font-size: 24px;
    color: #fff;
    line-height: 1.6;
    font-weight: 300;
  }

  @media (max-width: 1024px) {
    :global(.about-hero__title) {
      font-size: 40px;
    }

    :global(.about-hero__subtitle) {
      font-size: 18px;
    }
  }

  @media (max-width: 768px) {
    :global(.about-hero) {
      height: auto;
      min-height: 100vh;
      padding: 60px 20px;
    }

    :global(.about-hero__title) {
      font-size: 32px;
    }

    :global(.about-hero__subtitle) {
      font-size: 16px;
    }
  }
</style>
