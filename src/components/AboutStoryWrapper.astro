---
import AboutStory from './AboutStory';
---

<AboutStory client:visible />

<style>
  :global(.about-story) {
    background: #fff;
    padding: 100px 20px;
  }

  :global(.about-story__container) {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  :global(.about-story__image) {
    display: flex;
    justify-content: center;
  }

  :global(.about-story__placeholder) {
    width: 100%;
    max-width: 500px;
    aspect-ratio: 1;
    background: #d0d0d0;
  }

  :global(.about-story__img) {
    width: 100%;
    max-width: 500px;
    height: auto;
    object-fit: cover;
    display: block;
  }

  :global(.about-story__slider) {
    position: relative;
    width: 100%;
    max-width: 500px;
    aspect-ratio: 1;
    background: #222;
    overflow: hidden;
    min-height: 0;
  }

  :global(.about-story__img-slide) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.7s cubic-bezier(.4,0,.2,1);
    opacity: 0;
    z-index: 1;
    pointer-events: none;
  }

  :global(.about-story__img-slide.active) {
    opacity: 1;
    z-index: 2;
    pointer-events: auto;
  }

  :global(.about-story__slider-dots) {
    display: flex;
    justify-content: center;
    gap: 12px;
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
  }

  :global(.about-story__slider-dot) {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #e0e0e0;
    border: none;
    color: #222;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    outline: none;
    opacity: 0.7;
  }

  :global(.about-story__slider-dot.active) {
    background: #2b6eff;
    color: #fff;
    opacity: 1;
  }

  :global(.about-story__title) {
    font-family: 'Russo One', sans-serif;
    font-size: 40px;
    color: #262626;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  :global(.about-story__subtitle) {
    font-size: 18px;
    color: #2b6eff;
    font-weight: 600;
    margin-bottom: 32px;
  }

  :global(.about-story__text) {
    font-size: 16px;
    color: #666;
    line-height: 1.8;
  }

  :global(.about-story__text p) {
    margin-bottom: 16px;
  }

  :global(.about-story__highlight) {
    font-weight: 700;
    color: #262626;
    font-size: 18px;
    display: block;
    margin: 24px 0;
  }

  :global(.about-story__year) {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    margin-top: 40px;
  }

  :global(.about-story__year-number) {
    font-family: 'Russo One', sans-serif;
    font-size: 56px;
    color: #2b6eff;
    line-height: 1;
  }

  :global(.about-story__year-text) {
    font-size: 16px;
    color: #666;
    margin-bottom: 4px;
  }

  @media (max-width: 1280px) {
    :global(.about-story) {
      padding: 90px 40px;
    }

    :global(.about-story__container) {
      gap: 70px;
    }

    :global(.about-story__title) {
      font-size: 36px;
    }

    :global(.about-story__year-number) {
      font-size: 52px;
    }
  }

  @media (max-width: 1024px) {
    :global(.about-story__container) {
      grid-template-columns: 1fr;
      gap: 50px;
    }

    :global(.about-story__title) {
      font-size: 32px;
    }
  }

  @media (max-width: 768px) {
    :global(.about-story) {
      padding: 60px 20px;
    }

    :global(.about-story__title) {
      font-size: 24px;
    }

    :global(.about-story__text) {
      font-size: 15px;
    }

    :global(.about-story__year-number) {
      font-size: 48px;
    }
  }
</style>
