<style>
  .mobile-menu {
    position: fixed;
    left: -100%;
    top: 0;
    width: 100%;
    height: 100vh;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(10px);
    z-index: 99;
    transition: left 0.3s ease;
    overflow-y: auto;
    padding-top: 90px;
  }

  .mobile-menu.active {
    left: 0;
  }

  .menu-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px 40px;
    display: flex;
    flex-direction: column;
    gap: 60px;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
  }

  .menu-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .menu-title {
    font-size: 20px;
    font-weight: 600;
    color: #fff;
    font-family: 'Russo One', sans-serif;
    text-transform: uppercase;
    text-decoration: none;
    display: block;
    margin-bottom: 8px;
  }

  .menu-link {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    display: block;
    transition: color 0.3s;
  }

  .menu-link:hover {
    color: #fff;
  }

  .menu-phone {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    display: block;
    margin-bottom: 16px;
  }

  .menu-schedule {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.8;
    font-family: 'Helvetica', sans-serif;
  }

  @media (max-width: 1024px) {
    .menu-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }
  }

  @media (max-width: 768px) {
    .menu-content {
      padding: 40px 20px 30px;
      gap: 40px;
    }

    .menu-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .menu-title {
      font-size: 18px;
    }

    .menu-link {
      font-size: 15px;
    }

    .menu-phone {
      font-size: 16px;
    }

    .menu-schedule {
      font-size: 13px;
    }

    .menu-btn-request {
      padding: 14px 28px;
      font-size: 15px;
    }
  }

  @media (max-width: 480px) {
    .menu-content {
      padding: 30px 15px;
      gap: 30px;
    }

    .menu-title {
      font-size: 16px;
    }

    .menu-link {
      font-size: 14px;
    }
  }
</style>
