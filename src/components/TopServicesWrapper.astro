---
import TopServices from './TopServices';
---

<TopServices client:visible />

<style>
:global(.TopServices) {
  background-color: white;
  padding: 80px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

:global(.top-services-title) {
  font-family: 'Russo One', sans-serif;
  font-size: 32px;
  text-align: center;
  color: #262626;
  margin-bottom: 60px;
  text-transform: uppercase;
}

:global(.service-image) {
  height: 220px;
  object-fit: cover;
  margin: -12px -12px 0 -12px;
  max-width: none;
}

:global(.service-content) {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding-top: 16px;
  flex: 1;
}

:global(.service-content h3) {
  font-family: Helvetica, Arial, sans-serif;
  font-size: 20px;
  font-weight: 600;
  color: #262626;
  margin: 0;
  line-height: 1.3;
}

:global(.service-content p) {
  font-size: 14px;
  color: #666;
  margin: 0;
  line-height: 1.4;
  flex: 1;
}

:global(.service-footer) {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  padding-top: 12px;
}

:global(.price-from) {
  font-size: 16px;
  font-weight: 600;
  color: #2b6eff;
}

:global(.service-details-btn) {
  padding: 8px 16px;
  background: #2b6eff;
  color: white;
  border-radius: 4px;
  text-decoration: none;
  font-size: 13px;
  font-weight: 600;
  transition: none;
}

:global(.service-details-btn:hover) {
  background: #2b6eff;
  color: white;
  transform: none;
}

:global(.top-services-grid) {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  width: 100%;
  max-width: 1200px;
  margin-bottom: 50px;
}

:global(.top-service-card) {
  background: white;
  border: 1px solid #e0e0e0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 12px;
  transition: none;
  cursor: default;
  text-decoration: none;
}

:global(.services-button-wrapper) {
  display: flex;
  justify-content: center;
  width: 100%;
}

:global(.services-button) {
  padding: 20px 48px;
  background: black;
  color: white;
  font-size: 18px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s;
  cursor: pointer;
}

:global(.services-button:hover) {
  background: #2b6eff;
  color: white;
}

@media screen and (max-width: 1280px) {
  :global(.TopServices) {
    padding: 70px 40px;
  }

  :global(.top-services-title) {
    font-size: 30px;
    margin-bottom: 50px;
  }

  :global(.top-services-grid) {
    gap: 24px;
  }

  :global(.service-image-placeholder) {
    height: 200px;
  }

  :global(.service-content h3) {
    font-size: 18px;
  }

  :global(.service-content p) {
    font-size: 13px;
  }

  :global(.price-from) {
    font-size: 15px;
  }

  :global(.service-details-btn) {
    font-size: 12px;
    padding: 6px 12px;
  }
}

@media screen and (max-width: 1024px) {
  :global(.TopServices) {
    padding: 60px 30px;
  }

  :global(.top-services-title) {
    font-size: 28px;
    margin-bottom: 40px;
  }

  :global(.top-services-grid) {
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  :global(.service-image-placeholder) {
    height: 180px;
  }
}

@media screen and (max-width: 768px) {
  :global(.TopServices) {
    padding: 40px 20px;
  }

  :global(.top-services-title) {
    font-size: 24px;
    margin-bottom: 32px;
  }

  :global(.top-services-grid) {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  :global(.service-image-placeholder) {
    height: 160px;
  }

  :global(.service-content h3) {
    font-size: 17px;
  }

  :global(.service-content p) {
    font-size: 13px;
  }

  :global(.services-button) {
    padding: 16px 32px;
    font-size: 16px;
    width: 100%;
    text-align: center;
  }
}
</style>
